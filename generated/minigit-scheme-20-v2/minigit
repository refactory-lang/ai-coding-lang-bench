#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 regex)
             (rnrs bytevectors)
             (rnrs io ports)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-file path "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (read-file-string path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-string path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((content (read-file-string path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-string ".minigit/index" "")
        (write-file-string ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (if (not (file-exists? filename))
      (begin
        (display "File not found\n")
        (exit 1))
      (let ((hash (minihash-file filename)))
        ;; Store blob
        (let ((obj-path (string-append ".minigit/objects/" hash)))
          (unless (file-exists? obj-path)
            (copy-file-binary filename obj-path)))
        ;; Update index
        (let ((lines (read-lines ".minigit/index")))
          (unless (member filename lines)
            (let ((port (open-file ".minigit/index" "a")))
              (display filename port)
              (newline port)
              (close-port port)))))))

(define (cmd-commit args)
  ;; Parse -m "<message>"
  (let ((message #f))
    (let loop ((a args))
      (cond
       ((null? a) #f)
       ((string=? (car a) "-m")
        (if (null? (cdr a))
            (begin (display "No message provided\n") (exit 1))
            (set! message (cadr a))))
       (else (loop (cdr a)))))
    (unless message
      (display "No message provided\n")
      (exit 1))
    ;; Check index
    (let ((staged (read-lines ".minigit/index")))
      (when (null? staged)
        (display "Nothing to commit\n")
        (exit 1))
      ;; Build commit content
      (let* ((head (string-trim-both (read-file-string ".minigit/HEAD")))
             (parent (if (string=? head "") "NONE" head))
             (timestamp (number->string (car (gettimeofday))))
             (sorted-files (sort staged string<?))
             (file-entries
              (string-join
               (map (lambda (f)
                      (string-append f " " (minihash-file f)))
                    sorted-files)
               "\n"))
             (commit-content
              (string-append
               "parent: " parent "\n"
               "timestamp: " timestamp "\n"
               "message: " message "\n"
               "files:\n"
               file-entries "\n"))
             (commit-hash (minihash-string commit-content)))
        ;; Write commit
        (write-file-string
         (string-append ".minigit/commits/" commit-hash)
         commit-content)
        ;; Update HEAD
        (write-file-string ".minigit/HEAD" commit-hash)
        ;; Clear index
        (write-file-string ".minigit/index" "")
        ;; Print
        (format #t "Committed ~a\n" commit-hash)))))

(define (cmd-status)
  (let ((staged (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? staged)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) staged))))

(define (cmd-log)
  (let ((head (string-trim-both (read-file-string ".minigit/HEAD"))))
    (if (string=? head "")
        (display "No commits\n")
        (let loop ((hash head) (first #t))
          (when (and (not (string=? hash "")) (not (string=? hash "NONE")))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-string path)))
              (unless first (newline))
              ;; Parse commit
              (let* ((lines (string-split content #\newline))
                     (parent-line (car lines))
                     (timestamp-line (cadr lines))
                     (message-line (caddr lines))
                     (parent (substring parent-line 8))
                     (timestamp (substring timestamp-line 11))
                     (message (substring message-line 9)))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" message)
                (loop parent #f))))))))

(define (parse-commit-files content)
  "Parse a commit's files section, returning list of (filename . hash) pairs."
  (let* ((lines (string-split content #\newline))
         (files-idx (let loop ((ls lines) (i 0))
                      (cond ((null? ls) #f)
                            ((string=? (car ls) "files:") i)
                            (else (loop (cdr ls) (+ i 1)))))))
    (if files-idx
        (let loop ((ls (list-tail lines (+ files-idx 1))) (result '()))
          (if (or (null? ls) (string=? (car ls) ""))
              (reverse result)
              (let* ((line (car ls))
                     (sp (string-index line #\space))
                     (fname (substring line 0 sp))
                     (hash (substring line (+ sp 1))))
                (loop (cdr ls) (cons (cons fname hash) result)))))
        '())))

(define (cmd-diff args)
  (when (< (length args) 2)
    (display "Usage: minigit diff <commit1> <commit2>\n")
    (exit 1))
  (let* ((hash1 (car args))
         (hash2 (cadr args))
         (path1 (string-append ".minigit/commits/" hash1))
         (path2 (string-append ".minigit/commits/" hash2)))
    (when (not (file-exists? path1))
      (display "Invalid commit\n")
      (exit 1))
    (when (not (file-exists? path2))
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content1 (read-file-string path1))
           (content2 (read-file-string path2))
           (files1 (parse-commit-files content1))
           (files2 (parse-commit-files content2))
           (all-names (sort (delete-duplicates
                             (append (map car files1) (map car files2)))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((not (string=? (cdr in1) (cdr in2)))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout args)
  (when (null? args)
    (display "Usage: minigit checkout <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-string path))
           (files (parse-commit-files content)))
      (for-each
       (lambda (entry)
         (let* ((fname (car entry))
                (blob-hash (cdr entry))
                (blob-path (string-append ".minigit/objects/" blob-hash)))
           (copy-file-binary blob-path fname)))
       files)
      (write-file-string ".minigit/HEAD" hash)
      (write-file-string ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset args)
  (when (null? args)
    (display "Usage: minigit reset <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (write-file-string ".minigit/HEAD" hash)
    (write-file-string ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm args)
  (when (null? args)
    (display "Usage: minigit rm <file>\n")
    (exit 1))
  (let* ((filename (car args))
         (lines (read-lines ".minigit/index")))
    (if (not (member filename lines))
        (begin
          (display "File not in index\n")
          (exit 1))
        (let ((new-lines (filter (lambda (f) (not (string=? f filename))) lines)))
          (write-file-string ".minigit/index"
                             (if (null? new-lines)
                                 ""
                                 (string-append (string-join new-lines "\n") "\n")))))))

(define (cmd-show args)
  (when (null? args)
    (display "Usage: minigit show <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-string path))
           (lines (string-split content #\newline))
           (timestamp-line (cadr lines))
           (message-line (caddr lines))
           (timestamp (substring timestamp-line 11))
           (message (substring message-line 9))
           (files (parse-commit-files content)))
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" message)
      (display "Files:\n")
      (for-each
       (lambda (entry)
         (format #t "  ~a ~a\n" (car entry) (cdr entry)))
       files))))

;;; Main
(define (main args)
  (when (null? (cdr args))
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (cadr args))
        (rest (cddr args)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (if (null? rest)
          (begin (display "Usage: minigit add <file>\n") (exit 1))
          (cmd-add (car rest))))
     ((string=? cmd "commit") (cmd-commit rest))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff") (cmd-diff rest))
     ((string=? cmd "checkout") (cmd-checkout rest))
     ((string=? cmd "reset") (cmd-reset rest))
     ((string=? cmd "rm") (cmd-rm rest))
     ((string=? cmd "show") (cmd-show rest))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
