#!/usr/bin/env perl
use strict;
use warnings;
no warnings 'portable';
use File::Path qw(make_path);
my $MINIGIT_DIR = '.minigit';

sub minihash {
    my ($data) = @_;
    my @bytes = unpack('C*', $data);

    my $h_hi = 0x14650FB0;
    my $h_lo = 0x739D0383;

    my $p_hi = 0x00000100;
    my $p_lo = 0x000001B3;

    for my $b (@bytes) {
        # XOR with byte (only affects low part)
        $h_lo ^= $b;

        # Multiply (h_hi:h_lo) * (p_hi:p_lo) mod 2^64
        # result_lo = (h_lo * p_lo) mod 2^32, carry
        # result_hi = (h_hi * p_lo + h_lo * p_hi + carry) mod 2^32

        my $ll = $h_lo * $p_lo;
        my $r_lo = $ll & 0xFFFFFFFF;
        my $carry = int($ll / 4294967296); # $ll >> 32 but safe for large numbers

        my $r_hi = ($h_hi * $p_lo + $h_lo * $p_hi + $carry) & 0xFFFFFFFF;

        $h_hi = $r_hi;
        $h_lo = $r_lo;
    }

    return sprintf('%08x%08x', $h_hi, $h_lo);
}

sub read_file {
    my ($path) = @_;
    open my $fh, '<:raw', $path or return undef;
    local $/;
    my $content = <$fh>;
    close $fh;
    return $content;
}

sub write_file {
    my ($path, $content) = @_;
    open my $fh, '>:raw', $path or die "Cannot write $path: $!\n";
    print $fh $content;
    close $fh;
}

sub cmd_init {
    if (-d $MINIGIT_DIR) {
        print "Repository already initialized\n";
        return;
    }
    make_path("$MINIGIT_DIR/objects");
    make_path("$MINIGIT_DIR/commits");
    write_file("$MINIGIT_DIR/index", "");
    write_file("$MINIGIT_DIR/HEAD", "");
}

sub cmd_add {
    my ($file) = @_;
    unless (defined $file && -e $file) {
        print "File not found\n";
        exit 1;
    }

    my $content = read_file($file);
    my $hash = minihash($content);

    write_file("$MINIGIT_DIR/objects/$hash", $content);

    # Read current index
    my $index_content = read_file("$MINIGIT_DIR/index") // "";
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    unless (grep { $_ eq $file } @entries) {
        push @entries, $file;
        write_file("$MINIGIT_DIR/index", join("\n", @entries) . (@entries ? "\n" : ""));
    }
}

sub cmd_commit {
    my ($message) = @_;

    my $index_content = read_file("$MINIGIT_DIR/index") // "";
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    if (!@entries) {
        print "Nothing to commit\n";
        exit 1;
    }

    my $head = read_file("$MINIGIT_DIR/HEAD") // "";
    chomp $head;
    my $parent = $head eq '' ? 'NONE' : $head;

    my $timestamp = time();

    # Build file list sorted
    my @sorted = sort @entries;
    my @file_lines;
    for my $f (@sorted) {
        my $content = read_file($f);
        my $hash = minihash($content);
        push @file_lines, "$f $hash";
    }

    my $commit_content = "parent: $parent\n";
    $commit_content .= "timestamp: $timestamp\n";
    $commit_content .= "message: $message\n";
    $commit_content .= "files:\n";
    $commit_content .= join("\n", @file_lines) . "\n";

    my $commit_hash = minihash($commit_content);

    write_file("$MINIGIT_DIR/commits/$commit_hash", $commit_content);
    write_file("$MINIGIT_DIR/HEAD", $commit_hash);
    write_file("$MINIGIT_DIR/index", "");

    print "Committed $commit_hash\n";
}

sub cmd_log {
    my $head = read_file("$MINIGIT_DIR/HEAD") // "";
    chomp $head;

    if ($head eq '') {
        print "No commits\n";
        return;
    }

    my $current = $head;
    my $first = 1;
    while ($current ne 'NONE' && $current ne '') {
        my $commit_content = read_file("$MINIGIT_DIR/commits/$current");
        unless (defined $commit_content) {
            last;
        }

        print "\n" unless $first;
        $first = 0;

        my ($parent, $timestamp, $message);
        for my $line (split(/\n/, $commit_content)) {
            if ($line =~ /^parent: (.+)$/) {
                $parent = $1;
            } elsif ($line =~ /^timestamp: (.+)$/) {
                $timestamp = $1;
            } elsif ($line =~ /^message: (.+)$/) {
                $message = $1;
            }
        }

        print "commit $current\n";
        print "Date: $timestamp\n";
        print "Message: $message\n";

        $current = $parent // 'NONE';
    }
}

sub cmd_status {
    my $index_content = read_file("$MINIGIT_DIR/index") // "";
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    print "Staged files:\n";
    if (@entries) {
        for my $f (@entries) {
            print "$f\n";
        }
    } else {
        print "(none)\n";
    }
}

sub parse_commit_files {
    my ($commit_content) = @_;
    my %files;
    my $in_files = 0;
    for my $line (split(/\n/, $commit_content)) {
        if ($line eq 'files:') {
            $in_files = 1;
            next;
        }
        if ($in_files && $line =~ /^(\S+)\s+(\S+)$/) {
            $files{$1} = $2;
        }
    }
    return %files;
}

sub cmd_diff {
    my ($hash1, $hash2) = @_;

    my $c1 = read_file("$MINIGIT_DIR/commits/$hash1");
    unless (defined $c1) {
        print "Invalid commit\n";
        exit 1;
    }
    my $c2 = read_file("$MINIGIT_DIR/commits/$hash2");
    unless (defined $c2) {
        print "Invalid commit\n";
        exit 1;
    }

    my %files1 = parse_commit_files($c1);
    my %files2 = parse_commit_files($c2);

    my %all_files;
    $all_files{$_} = 1 for keys %files1;
    $all_files{$_} = 1 for keys %files2;

    for my $f (sort keys %all_files) {
        if (!exists $files1{$f} && exists $files2{$f}) {
            print "Added: $f\n";
        } elsif (exists $files1{$f} && !exists $files2{$f}) {
            print "Removed: $f\n";
        } elsif ($files1{$f} ne $files2{$f}) {
            print "Modified: $f\n";
        }
    }
}

sub cmd_checkout {
    my ($hash) = @_;

    my $commit_content = read_file("$MINIGIT_DIR/commits/$hash");
    unless (defined $commit_content) {
        print "Invalid commit\n";
        exit 1;
    }

    my %files = parse_commit_files($commit_content);
    for my $f (keys %files) {
        my $blob = read_file("$MINIGIT_DIR/objects/$files{$f}");
        write_file($f, $blob);
    }

    write_file("$MINIGIT_DIR/HEAD", $hash);
    write_file("$MINIGIT_DIR/index", "");

    print "Checked out $hash\n";
}

sub cmd_reset {
    my ($hash) = @_;

    my $commit_content = read_file("$MINIGIT_DIR/commits/$hash");
    unless (defined $commit_content) {
        print "Invalid commit\n";
        exit 1;
    }

    write_file("$MINIGIT_DIR/HEAD", $hash);
    write_file("$MINIGIT_DIR/index", "");

    print "Reset to $hash\n";
}

sub cmd_rm {
    my ($file) = @_;

    my $index_content = read_file("$MINIGIT_DIR/index") // "";
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    unless (grep { $_ eq $file } @entries) {
        print "File not in index\n";
        exit 1;
    }

    @entries = grep { $_ ne $file } @entries;
    write_file("$MINIGIT_DIR/index", @entries ? join("\n", @entries) . "\n" : "");
}

sub cmd_show {
    my ($hash) = @_;

    my $commit_content = read_file("$MINIGIT_DIR/commits/$hash");
    unless (defined $commit_content) {
        print "Invalid commit\n";
        exit 1;
    }

    my ($timestamp, $message);
    for my $line (split(/\n/, $commit_content)) {
        if ($line =~ /^timestamp: (.+)$/) {
            $timestamp = $1;
        } elsif ($line =~ /^message: (.+)$/) {
            $message = $1;
        }
    }

    my %files = parse_commit_files($commit_content);

    print "commit $hash\n";
    print "Date: $timestamp\n";
    print "Message: $message\n";
    print "Files:\n";
    for my $f (sort keys %files) {
        print "  $f $files{$f}\n";
    }
}

# Main
my $cmd = shift @ARGV;

unless (defined $cmd) {
    print "Usage: minigit <command>\n";
    exit 1;
}

if ($cmd eq 'init') {
    cmd_init();
} elsif ($cmd eq 'add') {
    cmd_add($ARGV[0]);
} elsif ($cmd eq 'commit') {
    # Parse -m "message"
    my $message;
    for (my $i = 0; $i < scalar @ARGV; $i++) {
        if ($ARGV[$i] eq '-m' && $i + 1 < scalar @ARGV) {
            $message = $ARGV[$i + 1];
            last;
        }
    }
    unless (defined $message) {
        print "Usage: minigit commit -m \"message\"\n";
        exit 1;
    }
    cmd_commit($message);
} elsif ($cmd eq 'log') {
    cmd_log();
} elsif ($cmd eq 'status') {
    cmd_status();
} elsif ($cmd eq 'diff') {
    cmd_diff($ARGV[0], $ARGV[1]);
} elsif ($cmd eq 'checkout') {
    cmd_checkout($ARGV[0]);
} elsif ($cmd eq 'reset') {
    cmd_reset($ARGV[0]);
} elsif ($cmd eq 'rm') {
    cmd_rm($ARGV[0]);
} elsif ($cmd eq 'show') {
    cmd_show($ARGV[0]);
} else {
    print "Unknown command: $cmd\n";
    exit 1;
}
