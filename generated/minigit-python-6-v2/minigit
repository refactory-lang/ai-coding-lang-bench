#!/usr/bin/env python3
import sys
import os

def minihash(data):
    h = 1469598103934665603
    for b in data:
        h ^= b
        h = (h * 1099511628211) % (2**64)
    return format(h, '016x')

def cmd_init():
    if os.path.isdir('.minigit'):
        print("Repository already initialized")
        return
    os.makedirs('.minigit/objects', exist_ok=True)
    os.makedirs('.minigit/commits', exist_ok=True)
    open('.minigit/index', 'w').close()
    open('.minigit/HEAD', 'w').close()

def cmd_add(filename):
    if not os.path.isfile(filename):
        print("File not found")
        sys.exit(1)
    data = open(filename, 'rb').read()
    h = minihash(data)
    with open(f'.minigit/objects/{h}', 'wb') as f:
        f.write(data)
    # Read current index
    with open('.minigit/index', 'r') as f:
        lines = [l.strip() for l in f if l.strip()]
    if filename not in lines:
        lines.append(filename)
    with open('.minigit/index', 'w') as f:
        for l in lines:
            f.write(l + '\n')

def cmd_commit(message):
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    if not files:
        print("Nothing to commit")
        sys.exit(1)
    head = open('.minigit/HEAD', 'r').read().strip()
    parent = head if head else 'NONE'
    timestamp = int(os.path.getmtime('.minigit/index')) if False else int(__import__('time').time())
    files_sorted = sorted(files)
    file_lines = []
    for fn in files_sorted:
        data = open(fn, 'rb').read()
        h = minihash(data)
        # Also store the blob
        with open(f'.minigit/objects/{h}', 'wb') as f:
            f.write(data)
        file_lines.append(f'{fn} {h}')
    content = f'parent: {parent}\ntimestamp: {timestamp}\nmessage: {message}\nfiles:\n'
    content += '\n'.join(file_lines) + '\n'
    commit_hash = minihash(content.encode())
    with open(f'.minigit/commits/{commit_hash}', 'w') as f:
        f.write(content)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    # Clear index
    open('.minigit/index', 'w').close()
    print(f'Committed {commit_hash}')

def cmd_log():
    head = open('.minigit/HEAD', 'r').read().strip()
    if not head:
        print("No commits")
        return
    current = head
    while current and current != 'NONE':
        path = f'.minigit/commits/{current}'
        with open(path, 'r') as f:
            lines = f.readlines()
        parent = None
        timestamp = None
        message = None
        for line in lines:
            if line.startswith('parent: '):
                parent = line[len('parent: '):].strip()
            elif line.startswith('timestamp: '):
                timestamp = line[len('timestamp: '):].strip()
            elif line.startswith('message: '):
                message = line[len('message: '):].strip()
        print(f'commit {current}')
        print(f'Date: {timestamp}')
        print(f'Message: {message}')
        print()
        current = parent if parent != 'NONE' else None

def cmd_status():
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    print("Staged files:")
    if files:
        for fn in files:
            print(fn)
    else:
        print("(none)")

def cmd_diff(hash1, hash2):
    p1 = f'.minigit/commits/{hash1}'
    p2 = f'.minigit/commits/{hash2}'
    if not os.path.isfile(p1) or not os.path.isfile(p2):
        print("Invalid commit")
        sys.exit(1)
    def parse_files(path):
        with open(path, 'r') as f:
            lines = f.readlines()
        result = {}
        in_files = False
        for line in lines:
            if line.strip() == 'files:':
                in_files = True
                continue
            if in_files and line.strip():
                parts = line.strip().split()
                result[parts[0]] = parts[1]
        return result
    f1 = parse_files(p1)
    f2 = parse_files(p2)
    all_files = sorted(set(list(f1.keys()) + list(f2.keys())))
    for fn in all_files:
        if fn not in f1:
            print(f"Added: {fn}")
        elif fn not in f2:
            print(f"Removed: {fn}")
        elif f1[fn] != f2[fn]:
            print(f"Modified: {fn}")

def cmd_checkout(commit_hash):
    path = f'.minigit/commits/{commit_hash}'
    if not os.path.isfile(path):
        print("Invalid commit")
        sys.exit(1)
    with open(path, 'r') as f:
        lines = f.readlines()
    in_files = False
    for line in lines:
        if line.strip() == 'files:':
            in_files = True
            continue
        if in_files and line.strip():
            parts = line.strip().split()
            fn, blob = parts[0], parts[1]
            with open(f'.minigit/objects/{blob}', 'rb') as bf:
                content = bf.read()
            with open(fn, 'wb') as wf:
                wf.write(content)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    open('.minigit/index', 'w').close()
    print(f"Checked out {commit_hash}")

def cmd_reset(commit_hash):
    path = f'.minigit/commits/{commit_hash}'
    if not os.path.isfile(path):
        print("Invalid commit")
        sys.exit(1)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    open('.minigit/index', 'w').close()
    print(f"Reset to {commit_hash}")

def cmd_rm(filename):
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    if filename not in files:
        print("File not in index")
        sys.exit(1)
    files.remove(filename)
    with open('.minigit/index', 'w') as f:
        for fn in files:
            f.write(fn + '\n')

def cmd_show(commit_hash):
    path = f'.minigit/commits/{commit_hash}'
    if not os.path.isfile(path):
        print("Invalid commit")
        sys.exit(1)
    with open(path, 'r') as f:
        lines = f.readlines()
    timestamp = None
    message = None
    file_entries = []
    in_files = False
    for line in lines:
        if line.startswith('timestamp: '):
            timestamp = line[len('timestamp: '):].strip()
        elif line.startswith('message: '):
            message = line[len('message: '):].strip()
        elif line.strip() == 'files:':
            in_files = True
        elif in_files and line.strip():
            file_entries.append(line.strip())
    print(f"commit {commit_hash}")
    print(f"Date: {timestamp}")
    print(f"Message: {message}")
    print("Files:")
    for entry in sorted(file_entries):
        print(f"  {entry}")

def main():
    if len(sys.argv) < 2:
        print("Usage: minigit <command>")
        sys.exit(1)
    cmd = sys.argv[1]
    if cmd == 'init':
        cmd_init()
    elif cmd == 'add':
        if len(sys.argv) < 3:
            print("Usage: minigit add <file>")
            sys.exit(1)
        cmd_add(sys.argv[2])
    elif cmd == 'commit':
        if len(sys.argv) < 4 or sys.argv[2] != '-m':
            print("Usage: minigit commit -m \"<message>\"")
            sys.exit(1)
        cmd_commit(sys.argv[3])
    elif cmd == 'log':
        cmd_log()
    elif cmd == 'status':
        cmd_status()
    elif cmd == 'diff':
        if len(sys.argv) < 4:
            print("Usage: minigit diff <commit1> <commit2>")
            sys.exit(1)
        cmd_diff(sys.argv[2], sys.argv[3])
    elif cmd == 'checkout':
        if len(sys.argv) < 3:
            print("Usage: minigit checkout <commit_hash>")
            sys.exit(1)
        cmd_checkout(sys.argv[2])
    elif cmd == 'reset':
        if len(sys.argv) < 3:
            print("Usage: minigit reset <commit_hash>")
            sys.exit(1)
        cmd_reset(sys.argv[2])
    elif cmd == 'rm':
        if len(sys.argv) < 3:
            print("Usage: minigit rm <file>")
            sys.exit(1)
        cmd_rm(sys.argv[2])
    elif cmd == 'show':
        if len(sys.argv) < 3:
            print("Usage: minigit show <commit_hash>")
            sys.exit(1)
        cmd_show(sys.argv[2])
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)

if __name__ == '__main__':
    main()
