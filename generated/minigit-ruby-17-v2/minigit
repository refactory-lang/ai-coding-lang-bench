#!/usr/bin/env ruby

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?('.minigit')
    puts 'Repository already initialized'
    return
  end
  Dir.mkdir('.minigit')
  Dir.mkdir('.minigit/objects')
  Dir.mkdir('.minigit/commits')
  File.write('.minigit/index', '')
  File.write('.minigit/HEAD', '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts 'File not found'
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(".minigit/objects/#{hash}", content)
  index = File.read('.minigit/index').split("\n").reject(&:empty?)
  unless index.include?(filename)
    index << filename
    File.write('.minigit/index', index.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index = File.read('.minigit/index').split("\n").reject(&:empty?)
  if index.empty?
    puts 'Nothing to commit'
    exit 1
  end

  head = File.read('.minigit/HEAD').strip
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  files_sorted = index.sort
  file_lines = files_sorted.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_lines.join("\n")}\n"
  commit_hash = minihash(commit_content)

  File.write(".minigit/commits/#{commit_hash}", commit_content)
  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')

  puts "Committed #{commit_hash}"
end

def cmd_status
  index = File.read('.minigit/index').split("\n").reject(&:empty?)
  puts 'Staged files:'
  if index.empty?
    puts '(none)'
  else
    index.each { |f| puts f }
  end
end

def parse_commit(hash)
  path = ".minigit/commits/#{hash}"
  unless File.exist?(path)
    return nil
  end
  content = File.read(path)
  parent = nil
  timestamp = nil
  message = nil
  files = {}
  in_files = false
  content.each_line do |line|
    if in_files
      parts = line.strip.split(' ', 2)
      files[parts[0]] = parts[1] if parts.length == 2 && !parts[0].empty?
    elsif line.start_with?('parent: ')
      parent = line.sub('parent: ', '').strip
    elsif line.start_with?('timestamp: ')
      timestamp = line.sub('timestamp: ', '').strip
    elsif line.start_with?('message: ')
      message = line.sub('message: ', '').strip
    elsif line.strip == 'files:'
      in_files = true
    end
  end
  { parent: parent, timestamp: timestamp, message: message, files: files }
end

def cmd_log
  head = File.read('.minigit/HEAD').strip
  if head.empty?
    puts 'No commits'
    return
  end

  current = head
  first = true
  while current && current != 'NONE' && !current.empty?
    commit = parse_commit(current)
    break unless commit

    puts '' unless first
    puts "commit #{current}"
    puts "Date: #{commit[:timestamp]}"
    puts "Message: #{commit[:message]}"

    first = false
    current = commit[:parent]
  end
end

def cmd_diff(hash1, hash2)
  c1 = parse_commit(hash1)
  c2 = parse_commit(hash2)
  unless c1 && c2
    puts 'Invalid commit'
    exit 1
  end

  files1 = c1[:files]
  files2 = c2[:files]
  all_files = (files1.keys + files2.keys).uniq.sort

  all_files.each do |f|
    if !files1.key?(f) && files2.key?(f)
      puts "Added: #{f}"
    elsif files1.key?(f) && !files2.key?(f)
      puts "Removed: #{f}"
    elsif files1[f] != files2[f]
      puts "Modified: #{f}"
    end
  end
end

def cmd_checkout(hash)
  commit = parse_commit(hash)
  unless commit
    puts 'Invalid commit'
    exit 1
  end

  commit[:files].each do |filename, blob_hash|
    blob_path = ".minigit/objects/#{blob_hash}"
    content = File.binread(blob_path)
    File.binwrite(filename, content)
  end

  File.write('.minigit/HEAD', hash)
  File.write('.minigit/index', '')
  puts "Checked out #{hash}"
end

def cmd_reset(hash)
  commit = parse_commit(hash)
  unless commit
    puts 'Invalid commit'
    exit 1
  end

  File.write('.minigit/HEAD', hash)
  File.write('.minigit/index', '')
  puts "Reset to #{hash}"
end

def cmd_rm(filename)
  index = File.read('.minigit/index').split("\n").reject(&:empty?)
  unless index.include?(filename)
    puts 'File not in index'
    exit 1
  end
  index.delete(filename)
  File.write('.minigit/index', index.empty? ? '' : index.join("\n") + "\n")
end

def cmd_show(hash)
  commit = parse_commit(hash)
  unless commit
    puts 'Invalid commit'
    exit 1
  end

  puts "commit #{hash}"
  puts "Date: #{commit[:timestamp]}"
  puts "Message: #{commit[:message]}"
  puts 'Files:'
  commit[:files].keys.sort.each do |f|
    puts "  #{f} #{commit[:files][f]}"
  end
end

case ARGV[0]
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  end
when 'status'
  cmd_status
when 'log'
  cmd_log
when 'diff'
  cmd_diff(ARGV[1], ARGV[2])
when 'checkout'
  cmd_checkout(ARGV[1])
when 'reset'
  cmd_reset(ARGV[1])
when 'rm'
  cmd_rm(ARGV[1])
when 'show'
  cmd_show(ARGV[1])
end
