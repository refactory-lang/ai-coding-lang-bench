#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 regex)
             (ice-9 textual-ports)
             (rnrs bytevectors)
             (rnrs io ports)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-file path "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists-not-dir? path)
  (and (file-exists? path)
       (not (eq? 'directory (stat:type (stat path))))))

(define (read-file-text path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (text (get-string-all port)))
        (close-port port)
        (if (eof-object? text) "" text))
      ""))

(define (write-file-text path text)
  (let ((port (open-output-file path)))
    (display text port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((text (read-file-text path)))
    (if (string=? text "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split text #\newline)))))

(define (ensure-dir path)
  (unless (file-exists? path)
    (mkdir path)))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (ensure-dir ".minigit")
        (ensure-dir ".minigit/objects")
        (ensure-dir ".minigit/commits")
        (write-file-text ".minigit/index" "")
        (write-file-text ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists-not-dir? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    (let ((obj-path (string-append ".minigit/objects/" hash)))
      (copy-file-binary filename obj-path))
    ;; Add to index if not already present
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((lines (read-lines ".minigit/index")))
    (when (null? lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-text (string-trim-both (read-file-text ".minigit/HEAD")))
           (parent (if (string=? head-text "") "NONE" head-text))
           (timestamp (inexact->exact (truncate (current-time))))
           (sorted-files (sort lines string<?))
           ;; Build file entries: for each file, get its blob hash
           (file-entries
            (map (lambda (f)
                   (let ((hash (minihash-file f)))
                     (string-append f " " hash)))
                 sorted-files))
           ;; Build commit content
           (commit-text
            (string-append
             "parent: " parent "\n"
             "timestamp: " (number->string timestamp) "\n"
             "message: " message "\n"
             "files:\n"
             (string-join file-entries "\n")
             "\n"))
           (commit-hash (minihash-string commit-text)))
      ;; Write commit file
      (write-file-text (string-append ".minigit/commits/" commit-hash) commit-text)
      ;; Update HEAD
      (write-file-text ".minigit/HEAD" commit-hash)
      ;; Clear index
      (write-file-text ".minigit/index" "")
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head-text (string-trim-both (read-file-text ".minigit/HEAD"))))
    (if (string=? head-text "")
        (display "No commits\n")
        (let loop ((hash head-text) (first #t))
          (when (and (not (string=? hash "")) (not (string=? hash "NONE")))
            (let* ((commit-path (string-append ".minigit/commits/" hash))
                   (text (read-file-text commit-path))
                   (lines (string-split text #\newline)))
              ;; Parse parent, timestamp, message from the commit text
              (let ((parent "NONE")
                    (timestamp "0")
                    (message ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! message (substring line 9)))))
                 lines)
                (unless first (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" message)
                (loop parent #f))))))))

(define (cmd-status)
  (let ((lines (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? lines)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) lines))))

(define (parse-commit-files text)
  ;; Parse the files section from commit text, return alist of (filename . hash)
  (let* ((lines (string-split text #\newline))
         (in-files #f)
         (result '()))
    (for-each
     (lambda (line)
       (cond
        ((string=? line "files:")
         (set! in-files #t))
        (in-files
         (when (not (string=? line ""))
           (let ((parts (string-split line #\space)))
             (when (>= (length parts) 2)
               (set! result (cons (cons (car parts) (cadr parts)) result))))))))
     lines)
    (reverse result)))

(define (parse-commit-field text prefix)
  (let ((lines (string-split text #\newline)))
    (let loop ((ls lines))
      (if (null? ls)
          ""
          (if (string-prefix? prefix (car ls))
              (substring (car ls) (string-length prefix))
              (loop (cdr ls)))))))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists? path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists? path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((text1 (read-file-text path1))
           (text2 (read-file-text path2))
           (files1 (parse-commit-files text1))
           (files2 (parse-commit-files text2))
           ;; Collect all filenames sorted
           (all-names (sort (delete-duplicates
                            (append (map car files1) (map car files2)))
                           string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((text (read-file-text path))
           (files (parse-commit-files text)))
      ;; Restore each file from objects
      (for-each
       (lambda (entry)
         (let ((filename (car entry))
               (blob-hash (cdr entry)))
           (copy-file-binary (string-append ".minigit/objects/" blob-hash) filename)))
       files)
      ;; Update HEAD
      (write-file-text ".minigit/HEAD" hash)
      ;; Clear index
      (write-file-text ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    ;; Update HEAD
    (write-file-text ".minigit/HEAD" hash)
    ;; Clear index
    (write-file-text ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm filename)
  (let ((lines (read-lines ".minigit/index")))
    (unless (member filename lines)
      (display "File not in index\n")
      (exit 1))
    (let ((new-lines (filter (lambda (f) (not (string=? f filename))) lines)))
      (if (null? new-lines)
          (write-file-text ".minigit/index" "")
          (write-file-text ".minigit/index"
                           (string-append (string-join new-lines "\n") "\n"))))))

(define (cmd-show hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((text (read-file-text path))
           (timestamp (parse-commit-field text "timestamp: "))
           (message (parse-commit-field text "message: "))
           (files (parse-commit-files text)))
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" message)
      (display "Files:\n")
      (for-each
       (lambda (entry)
         (format #t "  ~a ~a\n" (car entry) (cdr entry)))
       (sort files (lambda (a b) (string<? (car a) (car b))))))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (< (length args) 4)
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit_hash>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit_hash>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit_hash>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
