#!/usr/bin/env ruby

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?('.minigit')
    puts "Repository already initialized"
    exit 0
  end
  Dir.mkdir('.minigit')
  Dir.mkdir('.minigit/objects')
  Dir.mkdir('.minigit/commits')
  File.write('.minigit/index', '')
  File.write('.minigit/HEAD', '')
  exit 0
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts "File not found"
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(".minigit/objects/#{hash}", content)
  index = File.read('.minigit/index')
  lines = index.split("\n").reject(&:empty?)
  unless lines.include?(filename)
    lines << filename
    File.write('.minigit/index', lines.join("\n") + "\n")
  end
  exit 0
end

def cmd_commit(message)
  index = File.read('.minigit/index')
  lines = index.split("\n").reject(&:empty?)
  if lines.empty?
    puts "Nothing to commit"
    exit 1
  end

  head = File.read('.minigit/HEAD').strip
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  files_sorted = lines.sort
  file_entries = files_sorted.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_entries.join("\n")}\n"
  commit_hash = minihash(commit_content.b)

  File.write(".minigit/commits/#{commit_hash}", commit_content)
  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')

  puts "Committed #{commit_hash}"
  exit 0
end

def cmd_status
  index = File.read('.minigit/index')
  lines = index.split("\n").reject(&:empty?)
  puts "Staged files:"
  if lines.empty?
    puts "(none)"
  else
    lines.each { |f| puts f }
  end
  exit 0
end

def cmd_log
  head = File.read('.minigit/HEAD').strip
  if head.empty?
    puts "No commits"
    exit 0
  end

  current = head
  first = true
  while current && current != 'NONE' && !current.empty?
    path = ".minigit/commits/#{current}"
    break unless File.exist?(path)
    content = File.read(path)

    parent = nil
    timestamp = nil
    message = nil
    content.each_line do |line|
      if line.start_with?('parent: ')
        parent = line.sub('parent: ', '').strip
      elsif line.start_with?('timestamp: ')
        timestamp = line.sub('timestamp: ', '').strip
      elsif line.start_with?('message: ')
        message = line.sub('message: ', '').strip
      end
    end

    puts "" unless first
    puts "commit #{current}"
    puts "Date: #{timestamp}"
    puts "Message: #{message}"

    first = false
    current = parent
  end
  exit 0
end

def parse_commit_files(content)
  files = {}
  in_files = false
  content.each_line do |line|
    if line.strip == 'files:'
      in_files = true
    elsif in_files
      parts = line.strip.split(' ', 2)
      files[parts[0]] = parts[1] if parts.length == 2
    end
  end
  files
end

def parse_commit(content)
  parent = nil
  timestamp = nil
  message = nil
  content.each_line do |line|
    if line.start_with?('parent: ')
      parent = line.sub('parent: ', '').strip
    elsif line.start_with?('timestamp: ')
      timestamp = line.sub('timestamp: ', '').strip
    elsif line.start_with?('message: ')
      message = line.sub('message: ', '').strip
    end
  end
  { parent: parent, timestamp: timestamp, message: message }
end

def cmd_diff(hash1, hash2)
  path1 = ".minigit/commits/#{hash1}"
  path2 = ".minigit/commits/#{hash2}"
  unless File.exist?(path1) && File.exist?(path2)
    puts "Invalid commit"
    exit 1
  end

  files1 = parse_commit_files(File.read(path1))
  files2 = parse_commit_files(File.read(path2))

  all_files = (files1.keys + files2.keys).uniq.sort
  all_files.each do |f|
    if files1[f] && !files2[f]
      puts "Removed: #{f}"
    elsif !files1[f] && files2[f]
      puts "Added: #{f}"
    elsif files1[f] != files2[f]
      puts "Modified: #{f}"
    end
  end
  exit 0
end

def cmd_checkout(commit_hash)
  path = ".minigit/commits/#{commit_hash}"
  unless File.exist?(path)
    puts "Invalid commit"
    exit 1
  end

  files = parse_commit_files(File.read(path))
  files.each do |filename, blob_hash|
    blob_path = ".minigit/objects/#{blob_hash}"
    File.binwrite(filename, File.binread(blob_path))
  end

  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')
  puts "Checked out #{commit_hash}"
  exit 0
end

def cmd_reset(commit_hash)
  path = ".minigit/commits/#{commit_hash}"
  unless File.exist?(path)
    puts "Invalid commit"
    exit 1
  end

  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')
  puts "Reset to #{commit_hash}"
  exit 0
end

def cmd_rm(filename)
  index = File.read('.minigit/index')
  lines = index.split("\n").reject(&:empty?)
  unless lines.include?(filename)
    puts "File not in index"
    exit 1
  end
  lines.delete(filename)
  File.write('.minigit/index', lines.empty? ? '' : lines.join("\n") + "\n")
  exit 0
end

def cmd_show(commit_hash)
  path = ".minigit/commits/#{commit_hash}"
  unless File.exist?(path)
    puts "Invalid commit"
    exit 1
  end

  content = File.read(path)
  info = parse_commit(content)
  files = parse_commit_files(content)

  puts "commit #{commit_hash}"
  puts "Date: #{info[:timestamp]}"
  puts "Message: #{info[:message]}"
  puts "Files:"
  files.keys.sort.each do |f|
    puts "  #{f} #{files[f]}"
  end
  exit 0
end

# Main
command = ARGV[0]
case command
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  end
when 'status'
  cmd_status
when 'log'
  cmd_log
when 'diff'
  cmd_diff(ARGV[1], ARGV[2])
when 'checkout'
  cmd_checkout(ARGV[1])
when 'reset'
  cmd_reset(ARGV[1])
when 'rm'
  cmd_rm(ARGV[1])
when 'show'
  cmd_show(ARGV[1])
end
