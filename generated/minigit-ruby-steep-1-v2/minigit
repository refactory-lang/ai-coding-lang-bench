#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'

MINIGIT_DIR = '.minigit'
OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects')
COMMITS_DIR = File.join(MINIGIT_DIR, 'commits')
INDEX_FILE = File.join(MINIGIT_DIR, 'index')
HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD')

# MiniHash: FNV-1a variant, 64-bit, 16-char hex output
def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2 ** 64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?(MINIGIT_DIR)
    puts 'Repository already initialized'
    return
  end
  FileUtils.mkdir_p(OBJECTS_DIR)
  FileUtils.mkdir_p(COMMITS_DIR)
  File.write(INDEX_FILE, '')
  File.write(HEAD_FILE, '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    $stderr.puts 'File not found'
    exit 1
  end

  content = File.binread(filename)
  hash = minihash(content)
  blob_path = File.join(OBJECTS_DIR, hash)
  File.binwrite(blob_path, content)

  index_entries = read_index
  unless index_entries.include?(filename)
    index_entries << filename
    File.write(INDEX_FILE, index_entries.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index_entries = read_index
  if index_entries.empty?
    $stderr.puts 'Nothing to commit'
    exit 1
  end

  head = File.read(HEAD_FILE).strip
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  sorted_files = index_entries.sort
  file_lines = sorted_files.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_lines.join("\n")}\n"

  commit_hash = minihash(commit_content)
  commit_path = File.join(COMMITS_DIR, commit_hash)
  File.write(commit_path, commit_content)
  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')

  puts "Committed #{commit_hash}"
end

def cmd_status
  entries = read_index
  puts 'Staged files:'
  if entries.empty?
    puts '(none)'
  else
    entries.each { |f| puts f }
  end
end

def cmd_log
  head = File.read(HEAD_FILE).strip
  if head.empty?
    puts 'No commits'
    return
  end

  current = head
  while current && current != 'NONE' && !current.empty?
    commit_path = File.join(COMMITS_DIR, current)
    break unless File.exist?(commit_path)

    content = File.read(commit_path)
    parsed = parse_commit(content)

    puts "commit #{current}"
    puts "Date: #{parsed[:timestamp]}"
    puts "Message: #{parsed[:message]}"
    puts ''

    current = parsed[:parent]
  end
end

def cmd_diff(hash1, hash2)
  commit1_path = File.join(COMMITS_DIR, hash1)
  commit2_path = File.join(COMMITS_DIR, hash2)

  unless File.exist?(commit1_path) && File.exist?(commit2_path)
    $stderr.puts 'Invalid commit'
    exit 1
  end

  files1 = parse_commit(File.read(commit1_path))[:files]
  files2 = parse_commit(File.read(commit2_path))[:files]

  all_files = (files1.keys + files2.keys).uniq.sort

  all_files.each do |f|
    if files1.key?(f) && files2.key?(f)
      puts "Modified: #{f}" if files1[f] != files2[f]
    elsif files2.key?(f)
      puts "Added: #{f}"
    else
      puts "Removed: #{f}"
    end
  end
end

def cmd_checkout(commit_hash)
  commit_path = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_path)
    $stderr.puts 'Invalid commit'
    exit 1
  end

  files = parse_commit(File.read(commit_path))[:files]
  files.each do |filename, blob_hash|
    blob_path = File.join(OBJECTS_DIR, blob_hash)
    content = File.binread(blob_path)
    File.binwrite(filename, content)
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Checked out #{commit_hash}"
end

def cmd_reset(commit_hash)
  commit_path = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_path)
    $stderr.puts 'Invalid commit'
    exit 1
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Reset to #{commit_hash}"
end

def cmd_rm(filename)
  entries = read_index
  unless entries.include?(filename)
    $stderr.puts 'File not in index'
    exit 1
  end

  entries.delete(filename)
  if entries.empty?
    File.write(INDEX_FILE, '')
  else
    File.write(INDEX_FILE, entries.join("\n") + "\n")
  end
end

def cmd_show(commit_hash)
  commit_path = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_path)
    $stderr.puts 'Invalid commit'
    exit 1
  end

  parsed = parse_commit(File.read(commit_path))
  puts "commit #{commit_hash}"
  puts "Date: #{parsed[:timestamp]}"
  puts "Message: #{parsed[:message]}"
  puts 'Files:'
  parsed[:files].keys.sort.each do |f|
    puts "  #{f} #{parsed[:files][f]}"
  end
end

def parse_commit(content)
  parent = nil
  timestamp = nil
  message = nil
  files = {} #: Hash[String, String]
  in_files = false

  content.each_line do |line|
    line = line.chomp
    if in_files
      parts = line.split(' ', 2)
      files[parts[0]] = parts[1] if parts.length == 2
    elsif line.start_with?('parent: ')
      parent = line.sub('parent: ', '')
    elsif line.start_with?('timestamp: ')
      timestamp = line.sub('timestamp: ', '')
    elsif line.start_with?('message: ')
      message = line.sub('message: ', '')
    elsif line == 'files:'
      in_files = true
    end
  end

  { parent: parent, timestamp: timestamp, message: message, files: files }
end

def read_index
  return [] unless File.exist?(INDEX_FILE)

  content = File.read(INDEX_FILE).strip
  return [] if content.empty?

  content.split("\n")
end

def main
  if ARGV.empty?
    $stderr.puts 'Usage: minigit <command>'
    exit 1
  end

  command = ARGV[0]

  case command
  when 'init'
    cmd_init
  when 'add'
    if ARGV.length < 2
      $stderr.puts 'Usage: minigit add <file>'
      exit 1
    end
    cmd_add(ARGV[1])
  when 'commit'
    if ARGV.length < 3 || ARGV[1] != '-m'
      $stderr.puts 'Usage: minigit commit -m "<message>"'
      exit 1
    end
    cmd_commit(ARGV[2])
  when 'status'
    cmd_status
  when 'log'
    cmd_log
  when 'diff'
    if ARGV.length < 3
      $stderr.puts 'Usage: minigit diff <commit1> <commit2>'
      exit 1
    end
    cmd_diff(ARGV[1], ARGV[2])
  when 'checkout'
    if ARGV.length < 2
      $stderr.puts 'Usage: minigit checkout <commit_hash>'
      exit 1
    end
    cmd_checkout(ARGV[1])
  when 'reset'
    if ARGV.length < 2
      $stderr.puts 'Usage: minigit reset <commit_hash>'
      exit 1
    end
    cmd_reset(ARGV[1])
  when 'rm'
    if ARGV.length < 2
      $stderr.puts 'Usage: minigit rm <file>'
      exit 1
    end
    cmd_rm(ARGV[1])
  when 'show'
    if ARGV.length < 2
      $stderr.puts 'Usage: minigit show <commit_hash>'
      exit 1
    end
    cmd_show(ARGV[1])
  else
    $stderr.puts "Unknown command: #{command}"
    exit 1
  end
end

main
