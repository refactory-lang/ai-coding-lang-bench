#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 regex)
             (rnrs bytevectors)
             (rnrs io ports))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-file path "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (read-file-string path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-string path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((content (read-file-string path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-string ".minigit/index" "")
        (write-file-string ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (if (not (file-exists? filename))
      (begin
        (display "File not found\n")
        (exit 1))
      (let ((hash (minihash-file filename)))
        ;; Store blob
        (let ((obj-path (string-append ".minigit/objects/" hash)))
          (unless (file-exists? obj-path)
            (copy-file-binary filename obj-path)))
        ;; Update index
        (let ((lines (read-lines ".minigit/index")))
          (unless (member filename lines)
            (let ((port (open-file ".minigit/index" "a")))
              (display filename port)
              (newline port)
              (close-port port)))))))

(define (cmd-commit args)
  ;; Parse -m "<message>"
  (let ((message #f))
    (let loop ((a args))
      (cond
       ((null? a) #f)
       ((string=? (car a) "-m")
        (if (null? (cdr a))
            (begin (display "No message provided\n") (exit 1))
            (set! message (cadr a))))
       (else (loop (cdr a)))))
    (unless message
      (display "No message provided\n")
      (exit 1))
    ;; Check index
    (let ((staged (read-lines ".minigit/index")))
      (when (null? staged)
        (display "Nothing to commit\n")
        (exit 1))
      ;; Build commit content
      (let* ((head (string-trim-both (read-file-string ".minigit/HEAD")))
             (parent (if (string=? head "") "NONE" head))
             (timestamp (number->string (car (gettimeofday))))
             (sorted-files (sort staged string<?))
             (file-entries
              (string-join
               (map (lambda (f)
                      (string-append f " " (minihash-file f)))
                    sorted-files)
               "\n"))
             (commit-content
              (string-append
               "parent: " parent "\n"
               "timestamp: " timestamp "\n"
               "message: " message "\n"
               "files:\n"
               file-entries "\n"))
             (commit-hash (minihash-string commit-content)))
        ;; Write commit
        (write-file-string
         (string-append ".minigit/commits/" commit-hash)
         commit-content)
        ;; Update HEAD
        (write-file-string ".minigit/HEAD" commit-hash)
        ;; Clear index
        (write-file-string ".minigit/index" "")
        ;; Print
        (format #t "Committed ~a\n" commit-hash)))))

(define (cmd-log)
  (let ((head (string-trim-both (read-file-string ".minigit/HEAD"))))
    (if (string=? head "")
        (display "No commits\n")
        (let loop ((hash head) (first #t))
          (when (and (not (string=? hash "")) (not (string=? hash "NONE")))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-string path)))
              (unless first (newline))
              ;; Parse commit
              (let* ((lines (string-split content #\newline))
                     (parent-line (car lines))
                     (timestamp-line (cadr lines))
                     (message-line (caddr lines))
                     (parent (substring parent-line 8))
                     (timestamp (substring timestamp-line 11))
                     (message (substring message-line 9)))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" message)
                (loop parent #f))))))))

;;; Main
(define (main args)
  (when (null? (cdr args))
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (cadr args))
        (rest (cddr args)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (if (null? rest)
          (begin (display "Usage: minigit add <file>\n") (exit 1))
          (cmd-add (car rest))))
     ((string=? cmd "commit") (cmd-commit rest))
     ((string=? cmd "log") (cmd-log))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
