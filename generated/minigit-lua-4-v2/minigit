#!/usr/bin/env lua

-- MiniGit v1 implementation in Lua

local function mkdir_p(path)
    os.execute("mkdir -p " .. path)
end

local function file_exists(path)
    local f = io.open(path, "r")
    if f then f:close() return true end
    return false
end

local function dir_exists(path)
    local ok, _, code = os.execute("test -d " .. path)
    if ok == true then return true end
    if type(ok) == "number" then return ok == 0 end
    return false
end

local function read_file(path)
    local f = io.open(path, "rb")
    if not f then return nil end
    local content = f:read("*a")
    f:close()
    return content
end

local function write_file(path, content)
    local f = io.open(path, "wb")
    if not f then return false end
    f:write(content)
    f:close()
    return true
end

local function minihash(data)
    local h = 1469598103934665603
    for i = 1, #data do
        h = h ~ string.byte(data, i)
        h = h * 1099511628211
    end
    return string.format("%016x", h)
end

local function get_index()
    local content = read_file(".minigit/index")
    if not content or content == "" then return {} end
    local files = {}
    for line in content:gmatch("[^\n]+") do
        if line ~= "" then
            files[#files + 1] = line
        end
    end
    return files
end

local function write_index(files)
    if #files == 0 then
        write_file(".minigit/index", "")
    else
        write_file(".minigit/index", table.concat(files, "\n") .. "\n")
    end
end

local function get_head()
    local content = read_file(".minigit/HEAD")
    if not content then return nil end
    content = content:match("^%s*(.-)%s*$")  -- trim
    if content == "" then return nil end
    return content
end

-- Commands

local function cmd_init()
    if dir_exists(".minigit") then
        print("Repository already initialized")
        return 0
    end
    mkdir_p(".minigit/objects")
    mkdir_p(".minigit/commits")
    write_file(".minigit/index", "")
    write_file(".minigit/HEAD", "")
    return 0
end

local function cmd_add(filename)
    if not filename then
        io.stderr:write("Usage: minigit add <file>\n")
        os.exit(1)
    end

    if not file_exists(filename) then
        print("File not found")
        os.exit(1)
    end

    local content = read_file(filename)
    local hash = minihash(content)

    -- Store blob
    write_file(".minigit/objects/" .. hash, content)

    -- Update index
    local files = get_index()
    local found = false
    for _, f in ipairs(files) do
        if f == filename then found = true; break end
    end
    if not found then
        files[#files + 1] = filename
        write_index(files)
    end

    return 0
end

local function cmd_commit(args)
    -- Parse -m "message"
    local message = nil
    for i = 1, #args do
        if args[i] == "-m" and args[i+1] then
            message = args[i+1]
            break
        end
    end

    if not message then
        io.stderr:write("Usage: minigit commit -m \"<message>\"\n")
        os.exit(1)
    end

    local files = get_index()
    if #files == 0 then
        print("Nothing to commit")
        os.exit(1)
    end

    -- Sort filenames
    table.sort(files)

    -- Get parent
    local parent = get_head() or "NONE"

    -- Get timestamp
    local timestamp = tostring(os.time())

    -- Build file entries
    local file_entries = {}
    for _, fname in ipairs(files) do
        local content = read_file(fname)
        if content then
            local hash = minihash(content)
            file_entries[#file_entries + 1] = fname .. " " .. hash
        end
    end

    -- Build commit content
    local commit_content = "parent: " .. parent .. "\n"
        .. "timestamp: " .. timestamp .. "\n"
        .. "message: " .. message .. "\n"
        .. "files:\n"
        .. table.concat(file_entries, "\n") .. "\n"

    local commit_hash = minihash(commit_content)

    -- Write commit
    write_file(".minigit/commits/" .. commit_hash, commit_content)

    -- Update HEAD
    write_file(".minigit/HEAD", commit_hash)

    -- Clear index
    write_file(".minigit/index", "")

    print("Committed " .. commit_hash)
    return 0
end

local function cmd_log()
    local head = get_head()
    if not head then
        print("No commits")
        return 0
    end

    local current = head
    local first = true
    while current and current ~= "NONE" do
        local content = read_file(".minigit/commits/" .. current)
        if not content then break end

        -- Parse commit
        local parent_hash = content:match("parent: ([^\n]+)")
        local timestamp = content:match("timestamp: ([^\n]+)")
        local msg = content:match("message: ([^\n]+)")

        if not first then
            print("")
        end
        first = false

        print("commit " .. current)
        print("Date: " .. timestamp)
        print("Message: " .. msg)

        current = parent_hash
    end

    return 0
end

local function cmd_status()
    local files = get_index()
    print("Staged files:")
    if #files == 0 then
        print("(none)")
    else
        for _, f in ipairs(files) do
            print(f)
        end
    end
    return 0
end

local function parse_commit(content)
    local parent_hash = content:match("parent: ([^\n]+)")
    local timestamp = content:match("timestamp: ([^\n]+)")
    local msg = content:match("message: ([^\n]+)")
    local files_section = content:match("files:\n(.*)")
    local files = {}
    if files_section then
        for line in files_section:gmatch("[^\n]+") do
            local fname, hash = line:match("^(%S+)%s+(%S+)$")
            if fname and hash then
                files[fname] = hash
            end
        end
    end
    return { parent = parent_hash, timestamp = timestamp, message = msg, files = files }
end

local function cmd_diff(hash1, hash2)
    if not hash1 or not hash2 then
        io.stderr:write("Usage: minigit diff <commit1> <commit2>\n")
        os.exit(1)
    end

    local content1 = read_file(".minigit/commits/" .. hash1)
    if not content1 then
        print("Invalid commit")
        os.exit(1)
    end
    local content2 = read_file(".minigit/commits/" .. hash2)
    if not content2 then
        print("Invalid commit")
        os.exit(1)
    end

    local c1 = parse_commit(content1)
    local c2 = parse_commit(content2)

    -- Collect all filenames
    local all_files = {}
    local seen = {}
    for f, _ in pairs(c1.files) do
        if not seen[f] then all_files[#all_files + 1] = f; seen[f] = true end
    end
    for f, _ in pairs(c2.files) do
        if not seen[f] then all_files[#all_files + 1] = f; seen[f] = true end
    end
    table.sort(all_files)

    for _, f in ipairs(all_files) do
        local h1 = c1.files[f]
        local h2 = c2.files[f]
        if not h1 and h2 then
            print("Added: " .. f)
        elseif h1 and not h2 then
            print("Removed: " .. f)
        elseif h1 ~= h2 then
            print("Modified: " .. f)
        end
    end

    return 0
end

local function cmd_checkout(hash)
    if not hash then
        io.stderr:write("Usage: minigit checkout <commit_hash>\n")
        os.exit(1)
    end

    local content = read_file(".minigit/commits/" .. hash)
    if not content then
        print("Invalid commit")
        os.exit(1)
    end

    local c = parse_commit(content)

    -- Restore files from commit
    for fname, blob_hash in pairs(c.files) do
        local blob = read_file(".minigit/objects/" .. blob_hash)
        if blob then
            write_file(fname, blob)
        end
    end

    -- Update HEAD
    write_file(".minigit/HEAD", hash)

    -- Clear index
    write_file(".minigit/index", "")

    print("Checked out " .. hash)
    return 0
end

local function cmd_reset(hash)
    if not hash then
        io.stderr:write("Usage: minigit reset <commit_hash>\n")
        os.exit(1)
    end

    local content = read_file(".minigit/commits/" .. hash)
    if not content then
        print("Invalid commit")
        os.exit(1)
    end

    -- Update HEAD
    write_file(".minigit/HEAD", hash)

    -- Clear index
    write_file(".minigit/index", "")

    print("Reset to " .. hash)
    return 0
end

local function cmd_rm(filename)
    if not filename then
        io.stderr:write("Usage: minigit rm <file>\n")
        os.exit(1)
    end

    local files = get_index()
    local found = false
    local new_files = {}
    for _, f in ipairs(files) do
        if f == filename then
            found = true
        else
            new_files[#new_files + 1] = f
        end
    end

    if not found then
        print("File not in index")
        os.exit(1)
    end

    write_index(new_files)
    return 0
end

local function cmd_show(hash)
    if not hash then
        io.stderr:write("Usage: minigit show <commit_hash>\n")
        os.exit(1)
    end

    local content = read_file(".minigit/commits/" .. hash)
    if not content then
        print("Invalid commit")
        os.exit(1)
    end

    local c = parse_commit(content)

    print("commit " .. hash)
    print("Date: " .. c.timestamp)
    print("Message: " .. c.message)
    print("Files:")

    -- Sort files
    local sorted_files = {}
    for f, _ in pairs(c.files) do
        sorted_files[#sorted_files + 1] = f
    end
    table.sort(sorted_files)

    for _, f in ipairs(sorted_files) do
        print("  " .. f .. " " .. c.files[f])
    end

    return 0
end

-- Main
local args = arg
if #args < 1 then
    io.stderr:write("Usage: minigit <command> [args]\n")
    os.exit(1)
end

local command = args[1]

if command == "init" then
    os.exit(cmd_init())
elseif command == "add" then
    os.exit(cmd_add(args[2]))
elseif command == "commit" then
    local commit_args = {}
    for i = 2, #args do
        commit_args[#commit_args + 1] = args[i]
    end
    os.exit(cmd_commit(commit_args))
elseif command == "status" then
    os.exit(cmd_status())
elseif command == "log" then
    os.exit(cmd_log())
elseif command == "diff" then
    os.exit(cmd_diff(args[2], args[3]))
elseif command == "checkout" then
    os.exit(cmd_checkout(args[2]))
elseif command == "reset" then
    os.exit(cmd_reset(args[2]))
elseif command == "rm" then
    os.exit(cmd_rm(args[2]))
elseif command == "show" then
    os.exit(cmd_show(args[2]))
else
    io.stderr:write("Unknown command: " .. command .. "\n")
    os.exit(1)
end
