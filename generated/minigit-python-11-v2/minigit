#!/usr/bin/env python3
import sys
import os
import time

def minihash(data):
    h = 1469598103934665603
    for b in data:
        h ^= b
        h = (h * 1099511628211) % (2**64)
    return format(h, '016x')

def cmd_init():
    if os.path.isdir('.minigit'):
        print("Repository already initialized")
        return
    os.makedirs('.minigit/objects', exist_ok=True)
    os.makedirs('.minigit/commits', exist_ok=True)
    with open('.minigit/index', 'w') as f:
        pass
    with open('.minigit/HEAD', 'w') as f:
        pass

def cmd_add(filename):
    if not os.path.isfile(filename):
        print("File not found")
        sys.exit(1)
    with open(filename, 'rb') as f:
        data = f.read()
    h = minihash(data)
    with open(os.path.join('.minigit/objects', h), 'wb') as f:
        f.write(data)
    # Read current index
    with open('.minigit/index', 'r') as f:
        lines = [l.strip() for l in f if l.strip()]
    if filename not in lines:
        lines.append(filename)
    with open('.minigit/index', 'w') as f:
        for l in lines:
            f.write(l + '\n')

def cmd_commit(message):
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    if not files:
        print("Nothing to commit")
        sys.exit(1)
    with open('.minigit/HEAD', 'r') as f:
        parent = f.read().strip()
    parent_str = parent if parent else "NONE"
    timestamp = int(time.time())
    files_sorted = sorted(files)
    file_entries = []
    for fn in files_sorted:
        with open(fn, 'rb') as f:
            data = f.read()
        h = minihash(data)
        file_entries.append(f"{fn} {h}")
    content = f"parent: {parent_str}\ntimestamp: {timestamp}\nmessage: {message}\nfiles:\n"
    for entry in file_entries:
        content += entry + "\n"
    commit_hash = minihash(content.encode())
    with open(os.path.join('.minigit/commits', commit_hash), 'w') as f:
        f.write(content)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    # Clear index
    with open('.minigit/index', 'w') as f:
        pass
    print(f"Committed {commit_hash}")

def cmd_status():
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    print("Staged files:")
    if files:
        for fn in files:
            print(fn)
    else:
        print("(none)")

def parse_commit(commit_hash):
    path = os.path.join('.minigit/commits', commit_hash)
    if not os.path.isfile(path):
        return None
    with open(path, 'r') as f:
        lines = f.readlines()
    parent = None
    timestamp = None
    message = None
    file_list = []
    in_files = False
    for line in lines:
        line = line.rstrip('\n')
        if in_files:
            if line.strip():
                parts = line.split(' ', 1)
                if len(parts) == 2:
                    file_list.append((parts[0], parts[1]))
        elif line.startswith('parent: '):
            parent = line[len('parent: '):]
        elif line.startswith('timestamp: '):
            timestamp = line[len('timestamp: '):]
        elif line.startswith('message: '):
            message = line[len('message: '):]
        elif line == 'files:':
            in_files = True
    return {'parent': parent, 'timestamp': timestamp, 'message': message, 'files': file_list}

def cmd_diff(hash1, hash2):
    c1 = parse_commit(hash1)
    c2 = parse_commit(hash2)
    if c1 is None or c2 is None:
        print("Invalid commit")
        sys.exit(1)
    files1 = dict(c1['files'])
    files2 = dict(c2['files'])
    all_files = sorted(set(list(files1.keys()) + list(files2.keys())))
    for fn in all_files:
        if fn not in files1:
            print(f"Added: {fn}")
        elif fn not in files2:
            print(f"Removed: {fn}")
        elif files1[fn] != files2[fn]:
            print(f"Modified: {fn}")

def cmd_checkout(commit_hash):
    commit_path = os.path.join('.minigit/commits', commit_hash)
    if not os.path.isfile(commit_path):
        print("Invalid commit")
        sys.exit(1)
    c = parse_commit(commit_hash)
    for fn, blob_hash in c['files']:
        blob_path = os.path.join('.minigit/objects', blob_hash)
        with open(blob_path, 'rb') as f:
            data = f.read()
        with open(fn, 'wb') as f:
            f.write(data)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    with open('.minigit/index', 'w') as f:
        pass
    print(f"Checked out {commit_hash}")

def cmd_reset(commit_hash):
    commit_path = os.path.join('.minigit/commits', commit_hash)
    if not os.path.isfile(commit_path):
        print("Invalid commit")
        sys.exit(1)
    with open('.minigit/HEAD', 'w') as f:
        f.write(commit_hash)
    with open('.minigit/index', 'w') as f:
        pass
    print(f"Reset to {commit_hash}")

def cmd_rm(filename):
    with open('.minigit/index', 'r') as f:
        files = [l.strip() for l in f if l.strip()]
    if filename not in files:
        print("File not in index")
        sys.exit(1)
    files.remove(filename)
    with open('.minigit/index', 'w') as f:
        for fn in files:
            f.write(fn + '\n')

def cmd_show(commit_hash):
    c = parse_commit(commit_hash)
    if c is None:
        print("Invalid commit")
        sys.exit(1)
    print(f"commit {commit_hash}")
    print(f"Date: {c['timestamp']}")
    print(f"Message: {c['message']}")
    print("Files:")
    for fn, blob_hash in sorted(c['files']):
        print(f"  {fn} {blob_hash}")

def cmd_log():
    with open('.minigit/HEAD', 'r') as f:
        current = f.read().strip()
    if not current:
        print("No commits")
        return
    first = True
    while current:
        if not first:
            print()
        first = False
        commit_path = os.path.join('.minigit/commits', current)
        with open(commit_path, 'r') as f:
            lines = f.readlines()
        # Parse commit
        parent = None
        timestamp = None
        message = None
        for line in lines:
            line = line.rstrip('\n')
            if line.startswith('parent: '):
                parent = line[len('parent: '):]
            elif line.startswith('timestamp: '):
                timestamp = line[len('timestamp: '):]
            elif line.startswith('message: '):
                message = line[len('message: '):]
        print(f"commit {current}")
        print(f"Date: {timestamp}")
        print(f"Message: {message}")
        if parent and parent != "NONE":
            current = parent
        else:
            current = None

def main():
    if len(sys.argv) < 2:
        print("Usage: minigit <command>")
        sys.exit(1)
    cmd = sys.argv[1]
    if cmd == 'init':
        cmd_init()
    elif cmd == 'add':
        if len(sys.argv) < 3:
            print("Usage: minigit add <file>")
            sys.exit(1)
        cmd_add(sys.argv[2])
    elif cmd == 'commit':
        if len(sys.argv) < 4 or sys.argv[2] != '-m':
            print('Usage: minigit commit -m "<message>"')
            sys.exit(1)
        cmd_commit(sys.argv[3])
    elif cmd == 'status':
        cmd_status()
    elif cmd == 'log':
        cmd_log()
    elif cmd == 'diff':
        if len(sys.argv) < 4:
            print("Usage: minigit diff <commit1> <commit2>")
            sys.exit(1)
        cmd_diff(sys.argv[2], sys.argv[3])
    elif cmd == 'checkout':
        if len(sys.argv) < 3:
            print("Usage: minigit checkout <commit_hash>")
            sys.exit(1)
        cmd_checkout(sys.argv[2])
    elif cmd == 'reset':
        if len(sys.argv) < 3:
            print("Usage: minigit reset <commit_hash>")
            sys.exit(1)
        cmd_reset(sys.argv[2])
    elif cmd == 'rm':
        if len(sys.argv) < 3:
            print("Usage: minigit rm <file>")
            sys.exit(1)
        cmd_rm(sys.argv[2])
    elif cmd == 'show':
        if len(sys.argv) < 3:
            print("Usage: minigit show <commit_hash>")
            sys.exit(1)
        cmd_show(sys.argv[2])
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)

if __name__ == '__main__':
    main()
