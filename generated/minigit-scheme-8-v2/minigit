#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 match)
             (srfi srfi-1)
             (rnrs bytevectors))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-input-file path #:binary #t))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (read-file-content path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-content path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-input-file src #:binary #t))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-output-file dst #:binary #t)))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((content (read-file-content path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-content ".minigit/index" "")
        (write-file-content ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    (copy-file-binary filename (string-append ".minigit/objects/" hash))
    ;; Add to index if not already present
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((index-lines (read-lines ".minigit/index")))
    (when (null? index-lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (read-file-content ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (car (gettimeofday)))
           (sorted-files (sort index-lines string<?))
           (file-entries
            (string-join
             (map (lambda (fname)
                    (let* ((data (let* ((p (open-input-file fname #:binary #t))
                                        (d (get-bytevector-all p)))
                                   (close-port p)
                                   d))
                           (hash (if (eof-object? data)
                                     (minihash (make-bytevector 0))
                                     (minihash data))))
                      (string-append fname " " hash)))
                  sorted-files)
             "\n"))
           (commit-content
            (string-append "parent: " parent "\n"
                           "timestamp: " (number->string timestamp) "\n"
                           "message: " message "\n"
                           "files:\n"
                           file-entries "\n"))
           (commit-hash (minihash-string commit-content)))
      (write-file-content (string-append ".minigit/commits/" commit-hash)
                          commit-content)
      (write-file-content ".minigit/HEAD" commit-hash)
      (write-file-content ".minigit/index" "")
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-content ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content) (first #t))
          (unless (or (string=? hash "") (string=? hash "NONE"))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-content path))
                   (lines (string-split content #\newline)))
              ;; Parse parent, timestamp, message
              (let ((parent "NONE")
                    (timestamp "")
                    (msg ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! msg (substring line 9)))))
                 lines)
                (unless first (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" msg)
                (loop parent #f))))))))

(define (cmd-status)
  (let ((lines (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? lines)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) lines))))

(define (parse-commit-file path)
  ;; Returns an alist with parent, timestamp, message, and files (list of (name . hash))
  (let* ((content (read-file-content path))
         (lines (string-split content #\newline))
         (parent "NONE")
         (timestamp "")
         (msg "")
         (files '())
         (in-files #f))
    (for-each
     (lambda (line)
       (cond
        (in-files
         (unless (string=? line "")
           (let ((parts (string-split line #\space)))
             (when (>= (length parts) 2)
               (set! files (cons (cons (car parts) (cadr parts)) files))))))
        ((string-prefix? "parent: " line)
         (set! parent (substring line 8)))
        ((string-prefix? "timestamp: " line)
         (set! timestamp (substring line 11)))
        ((string-prefix? "message: " line)
         (set! msg (substring line 9)))
        ((string=? line "files:")
         (set! in-files #t))))
     lines)
    (list (cons 'parent parent)
          (cons 'timestamp timestamp)
          (cons 'message msg)
          (cons 'files (reverse files)))))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists? path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists? path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((parsed1 (parse-commit-file path1))
           (parsed2 (parse-commit-file path2))
           (files1 (assoc-ref parsed1 'files))
           (files2 (assoc-ref parsed2 'files))
           ;; Collect all filenames
           (all-names (sort (delete-duplicates
                             (append (map car files1) (map car files2)))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((parsed (parse-commit-file path))
           (files (assoc-ref parsed 'files)))
      (for-each
       (lambda (entry)
         (let* ((fname (car entry))
                (blob-hash (cdr entry))
                (blob-path (string-append ".minigit/objects/" blob-hash)))
           (copy-file-binary blob-path fname)))
       files)
      (write-file-content ".minigit/HEAD" hash)
      (write-file-content ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (write-file-content ".minigit/HEAD" hash)
    (write-file-content ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm filename)
  (let ((lines (read-lines ".minigit/index")))
    (unless (member filename lines)
      (display "File not in index\n")
      (exit 1))
    (let ((new-lines (filter (lambda (f) (not (string=? f filename))) lines)))
      (if (null? new-lines)
          (write-file-content ".minigit/index" "")
          (write-file-content ".minigit/index"
                              (string-append (string-join new-lines "\n") "\n"))))))

(define (cmd-show hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((parsed (parse-commit-file path))
           (timestamp (assoc-ref parsed 'timestamp))
           (msg (assoc-ref parsed 'message))
           (files (sort (assoc-ref parsed 'files)
                        (lambda (a b) (string<? (car a) (car b))))))
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" msg)
      (display "Files:\n")
      (for-each
       (lambda (entry)
         (format #t "  ~a ~a\n" (car entry) (cdr entry)))
       files))))

;;; Main dispatch
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (< (length args) 4)
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit_hash>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit_hash>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit_hash>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
