#!/usr/bin/env ruby

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?('.minigit')
    puts 'Repository already initialized'
    return
  end
  Dir.mkdir('.minigit')
  Dir.mkdir('.minigit/objects')
  Dir.mkdir('.minigit/commits')
  File.write('.minigit/index', '')
  File.write('.minigit/HEAD', '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts 'File not found'
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(".minigit/objects/#{hash}", content)

  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  unless entries.include?(filename)
    entries << filename
    File.write(index_path, entries.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  if entries.empty?
    puts 'Nothing to commit'
    exit 1
  end

  head = File.read('.minigit/HEAD').strip
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  files_sorted = entries.sort
  file_lines = files_sorted.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_lines.join("\n")}\n"

  commit_hash = minihash(commit_content.b)
  File.write(".minigit/commits/#{commit_hash}", commit_content)
  File.write('.minigit/HEAD', commit_hash)
  File.write(index_path, '')

  puts "Committed #{commit_hash}"
end

def cmd_status
  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  puts 'Staged files:'
  if entries.empty?
    puts '(none)'
  else
    entries.each { |f| puts f }
  end
end

def cmd_log
  head = File.read('.minigit/HEAD').strip
  if head.empty?
    puts 'No commits'
    return
  end

  current = head
  first = true
  while current && current != 'NONE' && !current.empty?
    commit_file = ".minigit/commits/#{current}"
    break unless File.exist?(commit_file)

    content = File.read(commit_file)
    lines = content.split("\n")

    parent_line = lines.find { |l| l.start_with?('parent:') }
    timestamp_line = lines.find { |l| l.start_with?('timestamp:') }
    message_line = lines.find { |l| l.start_with?('message:') }

    parent = parent_line.split(' ', 2)[1].strip
    timestamp = timestamp_line.split(' ', 2)[1].strip
    message = message_line.split(' ', 2)[1].strip

    puts '' unless first
    puts "commit #{current}"
    puts "Date: #{timestamp}"
    puts "Message: #{message}"

    first = false
    current = parent
  end
end

def parse_commit_files(commit_hash)
  commit_file = ".minigit/commits/#{commit_hash}"
  unless File.exist?(commit_file)
    puts 'Invalid commit'
    exit 1
  end
  content = File.read(commit_file)
  files = {}
  in_files = false
  content.split("\n").each do |line|
    if line == 'files:'
      in_files = true
      next
    end
    if in_files && !line.empty?
      parts = line.split(' ', 2)
      files[parts[0]] = parts[1]
    end
  end
  files
end

def cmd_diff(hash1, hash2)
  files1 = parse_commit_files(hash1)
  files2 = parse_commit_files(hash2)

  all_files = (files1.keys + files2.keys).uniq.sort
  all_files.each do |f|
    if files1.key?(f) && files2.key?(f)
      puts "Modified: #{f}" if files1[f] != files2[f]
    elsif files2.key?(f)
      puts "Added: #{f}"
    else
      puts "Removed: #{f}"
    end
  end
end

def cmd_checkout(commit_hash)
  commit_file = ".minigit/commits/#{commit_hash}"
  unless File.exist?(commit_file)
    puts 'Invalid commit'
    exit 1
  end

  files = parse_commit_files(commit_hash)
  files.each do |filename, blob_hash|
    blob_content = File.binread(".minigit/objects/#{blob_hash}")
    File.binwrite(filename, blob_content)
  end

  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')

  puts "Checked out #{commit_hash}"
end

def cmd_reset(commit_hash)
  commit_file = ".minigit/commits/#{commit_hash}"
  unless File.exist?(commit_file)
    puts 'Invalid commit'
    exit 1
  end

  File.write('.minigit/HEAD', commit_hash)
  File.write('.minigit/index', '')

  puts "Reset to #{commit_hash}"
end

def cmd_rm(filename)
  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  unless entries.include?(filename)
    puts 'File not in index'
    exit 1
  end
  entries.delete(filename)
  File.write(index_path, entries.empty? ? '' : entries.join("\n") + "\n")
end

def cmd_show(commit_hash)
  commit_file = ".minigit/commits/#{commit_hash}"
  unless File.exist?(commit_file)
    puts 'Invalid commit'
    exit 1
  end

  content = File.read(commit_file)
  lines = content.split("\n")

  timestamp_line = lines.find { |l| l.start_with?('timestamp:') }
  message_line = lines.find { |l| l.start_with?('message:') }

  timestamp = timestamp_line.split(' ', 2)[1].strip
  message = message_line.split(' ', 2)[1].strip

  files = parse_commit_files(commit_hash)

  puts "commit #{commit_hash}"
  puts "Date: #{timestamp}"
  puts "Message: #{message}"
  puts 'Files:'
  files.keys.sort.each do |f|
    puts "  #{f} #{files[f]}"
  end
end

command = ARGV[0]
case command
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  end
when 'status'
  cmd_status
when 'log'
  cmd_log
when 'diff'
  cmd_diff(ARGV[1], ARGV[2])
when 'checkout'
  cmd_checkout(ARGV[1])
when 'reset'
  cmd_reset(ARGV[1])
when 'rm'
  cmd_rm(ARGV[1])
when 'show'
  cmd_show(ARGV[1])
end
