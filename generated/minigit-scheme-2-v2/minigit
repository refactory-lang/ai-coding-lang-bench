#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 regex)
             (rnrs bytevectors)
             (srfi srfi-1))

;;; ---- MiniHash (FNV-1a variant, 64-bit) ----

(define *2^64* (expt 2 64))
(define *fnv-offset* 1469598103934665603)
(define *fnv-prime*  1099511628211)

(define (minihash bv)
  "Compute MiniHash over a bytevector. Returns 16-char hex string."
  (let ((len (bytevector-length bv)))
    (let loop ((i 0) (h *fnv-offset*))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h *2^64*))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 *fnv-prime*) *2^64*)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  "Compute MiniHash over a string (UTF-8 encoded)."
  (minihash (string->utf8 str)))

(define (read-file-bytes path)
  "Read a file as a bytevector."
  (call-with-input-file path
    (lambda (port)
      (get-bytevector-all port))
    #:binary #t))

(define (read-file-text path)
  "Read a file as a string."
  (call-with-input-file path
    (lambda (port)
      (get-string-all port))))

(define (write-file-text path content)
  "Write a string to a file."
  (call-with-output-file path
    (lambda (port)
      (display content port))))

(define (file-exists-regular? path)
  "Check if path exists and is a regular file."
  (and (file-exists? path)
       (eq? 'regular (stat:type (stat path)))))

(define (ensure-directory path)
  "Create directory if it doesn't exist."
  (unless (file-exists? path)
    (mkdir path)))

;;; ---- init ----

(define (cmd-init)
  (if (file-exists? ".minigit")
      (begin
        (display "Repository already initialized\n"))
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-text ".minigit/index" "")
        (write-file-text ".minigit/HEAD" ""))))

;;; ---- add ----

(define (read-index)
  "Read the index file, returning a list of filenames."
  (let ((content (read-file-text ".minigit/index")))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

(define (write-index filenames)
  "Write filenames to the index file (one per line)."
  (if (null? filenames)
      (write-file-text ".minigit/index" "")
      (write-file-text ".minigit/index"
                       (string-append (string-join filenames "\n") "\n"))))

(define (cmd-add filename)
  (unless (file-exists-regular? filename)
    (display "File not found\n")
    (exit 1))
  (let* ((bv (read-file-bytes filename))
         (hash (minihash bv))
         (obj-path (string-append ".minigit/objects/" hash)))
    ;; Write blob
    (unless (file-exists? obj-path)
      (let ((content (utf8->string bv)))
        (write-file-text obj-path content)))
    ;; Update index
    (let ((index (read-index)))
      (unless (member filename index)
        (write-index (append index (list filename)))))))

;;; ---- commit ----

(define (cmd-commit message)
  (let ((index (read-index)))
    (when (null? index)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (read-file-text ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (number->string (car (gettimeofday))))
           (sorted-files (sort index string<?))
           ;; Build file entries
           (file-entries
            (map (lambda (fname)
                   (let* ((bv (read-file-bytes fname))
                          (hash (minihash bv)))
                     (string-append fname " " hash)))
                 sorted-files))
           ;; Build commit content
           (commit-content
            (string-append
             "parent: " parent "\n"
             "timestamp: " timestamp "\n"
             "message: " message "\n"
             "files:\n"
             (string-join file-entries "\n") "\n"))
           (commit-hash (minihash-string commit-content)))
      ;; Write commit file
      (write-file-text (string-append ".minigit/commits/" commit-hash)
                       commit-content)
      ;; Update HEAD
      (write-file-text ".minigit/HEAD" commit-hash)
      ;; Clear index
      (write-file-text ".minigit/index" "")
      ;; Print
      (display (string-append "Committed " commit-hash "\n")))))

;;; ---- log ----

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-text ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content))
          (let* ((commit-path (string-append ".minigit/commits/" hash))
                 (content (read-file-text commit-path))
                 (lines (string-split content #\newline)))
            ;; Parse parent, timestamp, message
            (let ((parent "NONE")
                  (timestamp "")
                  (message ""))
              (for-each
               (lambda (line)
                 (cond
                  ((string-prefix? "parent: " line)
                   (set! parent (substring line 8)))
                  ((string-prefix? "timestamp: " line)
                   (set! timestamp (substring line 11)))
                  ((string-prefix? "message: " line)
                   (set! message (substring line 9)))))
               lines)
              (display (string-append "commit " hash "\n"))
              (display (string-append "Date: " timestamp "\n"))
              (display (string-append "Message: " message "\n"))
              (display "\n")
              (unless (string=? parent "NONE")
                (loop parent))))))))

;;; ---- status ----

(define (cmd-status)
  (let ((index (read-index)))
    (display "Staged files:\n")
    (if (null? index)
        (display "(none)\n")
        (for-each (lambda (f) (display (string-append f "\n"))) index))))

;;; ---- diff ----

(define (parse-commit-files content)
  "Parse the files section of a commit, returning alist of (filename . hash)."
  (let* ((lines (string-split content #\newline))
         (result '())
         (in-files #f))
    (for-each
     (lambda (line)
       (cond
        ((string=? line "files:")
         (set! in-files #t))
        (in-files
         (let ((parts (string-split line #\space)))
           (when (and (>= (length parts) 2)
                      (not (string=? (car parts) "")))
             (set! result (cons (cons (car parts) (cadr parts)) result)))))))
     lines)
    (reverse result)))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists? path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists? path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((files1 (parse-commit-files (read-file-text path1)))
           (files2 (parse-commit-files (read-file-text path2)))
           (all-names (sort (delete-duplicates
                             (append (map car files1) (map car files2)))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and (not in1) in2)
             (display (string-append "Added: " name "\n")))
            ((and in1 (not in2))
             (display (string-append "Removed: " name "\n")))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (display (string-append "Modified: " name "\n"))))))
       all-names))))

;;; ---- checkout ----

(define (cmd-checkout hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    (let ((files (parse-commit-files (read-file-text commit-path))))
      (for-each
       (lambda (entry)
         (let* ((fname (car entry))
                (blob-hash (cdr entry))
                (blob-path (string-append ".minigit/objects/" blob-hash))
                (content (read-file-text blob-path)))
           (write-file-text fname content)))
       files)
      (write-file-text ".minigit/HEAD" hash)
      (write-file-text ".minigit/index" "")
      (display (string-append "Checked out " hash "\n")))))

;;; ---- reset ----

(define (cmd-reset hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    (write-file-text ".minigit/HEAD" hash)
    (write-file-text ".minigit/index" "")
    (display (string-append "Reset to " hash "\n"))))

;;; ---- rm ----

(define (cmd-rm filename)
  (let ((index (read-index)))
    (unless (member filename index)
      (display "File not in index\n")
      (exit 1))
    (write-index (filter (lambda (f) (not (string=? f filename))) index))))

;;; ---- show ----

(define (cmd-show hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-text commit-path))
           (lines (string-split content #\newline))
           (timestamp "")
           (message "")
           (files (parse-commit-files content)))
      (for-each
       (lambda (line)
         (cond
          ((string-prefix? "timestamp: " line)
           (set! timestamp (substring line 11)))
          ((string-prefix? "message: " line)
           (set! message (substring line 9)))))
       lines)
      (display (string-append "commit " hash "\n"))
      (display (string-append "Date: " timestamp "\n"))
      (display (string-append "Message: " message "\n"))
      (display "Files:\n")
      (for-each
       (lambda (entry)
         (display (string-append "  " (car entry) " " (cdr entry) "\n")))
       (sort files (lambda (a b) (string<? (car a) (car b))))))))

;;; ---- Main dispatch ----

(define (main args)
  (let ((args (cdr args))) ; skip program name
    (when (null? args)
      (display "Usage: minigit <command> [args]\n")
      (exit 1))
    (let ((cmd (car args)))
      (cond
       ((string=? cmd "init")
        (cmd-init))
       ((string=? cmd "add")
        (when (null? (cdr args))
          (display "Usage: minigit add <file>\n")
          (exit 1))
        (cmd-add (cadr args)))
       ((string=? cmd "commit")
        ;; Parse -m "message"
        (let loop ((rest (cdr args)) (message #f))
          (cond
           ((null? rest)
            (if message
                (cmd-commit message)
                (begin
                  (display "Usage: minigit commit -m \"<message>\"\n")
                  (exit 1))))
           ((string=? (car rest) "-m")
            (if (null? (cdr rest))
                (begin
                  (display "Usage: minigit commit -m \"<message>\"\n")
                  (exit 1))
                (loop (cddr rest) (cadr rest))))
           (else
            (loop (cdr rest) message)))))
       ((string=? cmd "status")
        (cmd-status))
       ((string=? cmd "log")
        (cmd-log))
       ((string=? cmd "diff")
        (when (or (null? (cdr args)) (null? (cddr args)))
          (display "Usage: minigit diff <commit1> <commit2>\n")
          (exit 1))
        (cmd-diff (cadr args) (caddr args)))
       ((string=? cmd "checkout")
        (when (null? (cdr args))
          (display "Usage: minigit checkout <commit_hash>\n")
          (exit 1))
        (cmd-checkout (cadr args)))
       ((string=? cmd "reset")
        (when (null? (cdr args))
          (display "Usage: minigit reset <commit_hash>\n")
          (exit 1))
        (cmd-reset (cadr args)))
       ((string=? cmd "rm")
        (when (null? (cdr args))
          (display "Usage: minigit rm <file>\n")
          (exit 1))
        (cmd-rm (cadr args)))
       ((string=? cmd "show")
        (when (null? (cdr args))
          (display "Usage: minigit show <commit_hash>\n")
          (exit 1))
        (cmd-show (cadr args)))
       (else
        (display (string-append "Unknown command: " cmd "\n"))
        (exit 1))))))

(main (command-line))
