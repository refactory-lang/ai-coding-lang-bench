#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 regex)
             (rnrs bytevectors)
             (rnrs io ports)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (logand h #xFFFFFFFFFFFFFFFF))
          (let* ((b (bytevector-u8-ref bv i))
                 (h2 (logxor h b))
                 (h3 (modulo (* h2 1099511628211) (expt 2 64))))
            (loop (+ i 1) h3))))))

(define (minihash-file filename)
  (let* ((port (open-file filename "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

;;; File helpers
(define (file-exists-regular? path)
  (and (file-exists? path)
       (eq? 'regular (stat:type (stat path)))))

(define (read-file-text path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (text (get-string-all port)))
        (close-port port)
        (if (eof-object? text) "" text))
      ""))

(define (write-file-text path text)
  (let ((port (open-output-file path)))
    (display text port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-index)
  (let ((text (read-file-text ".minigit/index")))
    (if (string=? text "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split text #\newline)))))

(define (write-index entries)
  (if (null? entries)
      (write-file-text ".minigit/index" "")
      (write-file-text ".minigit/index"
                       (string-append (string-join entries "\n") "\n"))))

(define (read-head)
  (let ((text (read-file-text ".minigit/HEAD")))
    (string-trim-right text)))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-text ".minigit/index" "")
        (write-file-text ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (if (not (file-exists-regular? filename))
      (begin
        (display "File not found\n")
        (exit 1))
      (let ((hash (minihash-file filename)))
        (let ((objpath (string-append ".minigit/objects/" hash)))
          (unless (file-exists? objpath)
            (copy-file-binary filename objpath)))
        (let ((entries (read-index)))
          (unless (member filename entries)
            (write-index (append entries (list filename))))))))

(define (cmd-commit message)
  (let ((entries (read-index)))
    (if (null? entries)
        (begin
          (display "Nothing to commit\n")
          (exit 1))
        (let* ((sorted (sort entries string<?))
               (head (read-head))
               (parent (if (string=? head "") "NONE" head))
               (timestamp (number->string (current-time)))
               (file-lines
                (map (lambda (f)
                       (let* ((data (let* ((p (open-file f "rb"))
                                           (d (get-bytevector-all p)))
                                      (close-port p)
                                      d))
                              (hash (if (eof-object? data)
                                        (minihash (make-bytevector 0))
                                        (minihash data))))
                         (string-append f " " hash)))
                     sorted))
               (commit-content
                (string-append
                 "parent: " parent "\n"
                 "timestamp: " timestamp "\n"
                 "message: " message "\n"
                 "files:\n"
                 (string-join file-lines "\n") "\n"))
               (commit-hash (minihash-string commit-content)))
          (write-file-text (string-append ".minigit/commits/" commit-hash)
                           commit-content)
          (write-file-text ".minigit/HEAD" commit-hash)
          (write-file-text ".minigit/index" "")
          (format #t "Committed ~a\n" commit-hash)))))

(define (cmd-log)
  (let ((head (read-head)))
    (if (string=? head "")
        (display "No commits\n")
        (let loop ((hash head) (first #t))
          (unless (or (string=? hash "") (string=? hash "NONE"))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-text path))
                   (lines (string-split content #\newline)))
              (unless first (newline))
              (format #t "commit ~a\n" hash)
              ;; Parse timestamp and message from lines
              (for-each
               (lambda (line)
                 (cond
                  ((string-prefix? "timestamp: " line)
                   (format #t "Date: ~a\n"
                           (substring line (string-length "timestamp: "))))
                  ((string-prefix? "message: " line)
                   (format #t "Message: ~a\n"
                           (substring line (string-length "message: "))))))
               lines)
              ;; Find parent
              (let ((parent-line (find (lambda (l) (string-prefix? "parent: " l)) lines)))
                (if parent-line
                    (let ((parent (substring parent-line (string-length "parent: "))))
                      (loop parent #f))))))))))

(define (cmd-status)
  (let ((entries (read-index)))
    (display "Staged files:\n")
    (if (null? entries)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) entries))))

(define (parse-commit-files content)
  ;; Parse the files section from commit content
  (let* ((lines (string-split content #\newline))
         (file-lines (let loop ((ls lines) (in-files #f) (acc '()))
                       (if (null? ls)
                           (reverse acc)
                           (let ((line (car ls)))
                             (cond
                              ((string=? line "files:")
                               (loop (cdr ls) #t acc))
                              (in-files
                               (if (string=? line "")
                                   (loop (cdr ls) in-files acc)
                                   (loop (cdr ls) #t (cons line acc))))
                              (else
                               (loop (cdr ls) #f acc))))))))
    ;; Each line is "filename hash"
    (map (lambda (line)
           (let ((sp (string-index line #\space)))
             (cons (substring line 0 sp)
                   (substring line (+ sp 1)))))
         file-lines)))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (when (not (file-exists? path1))
      (display "Invalid commit\n")
      (exit 1))
    (when (not (file-exists? path2))
      (display "Invalid commit\n")
      (exit 1))
    (let* ((files1 (parse-commit-files (read-file-text path1)))
           (files2 (parse-commit-files (read-file-text path2)))
           (names1 (map car files1))
           (names2 (map car files2))
           (all-names (sort (delete-duplicates (append names1 names2)) string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (let ((files (parse-commit-files (read-file-text path))))
      (for-each
       (lambda (entry)
         (let* ((filename (car entry))
                (blob-hash (cdr entry))
                (blob-path (string-append ".minigit/objects/" blob-hash)))
           (copy-file-binary blob-path filename)))
       files)
      (write-file-text ".minigit/HEAD" hash)
      (write-file-text ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (write-file-text ".minigit/HEAD" hash)
    (write-file-text ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm filename)
  (let ((entries (read-index)))
    (if (not (member filename entries))
        (begin
          (display "File not in index\n")
          (exit 1))
        (write-index (filter (lambda (e) (not (string=? e filename))) entries)))))

(define (cmd-show hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (when (not (file-exists? path))
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-text path))
           (lines (string-split content #\newline))
           (files (parse-commit-files content)))
      (format #t "commit ~a\n" hash)
      (for-each
       (lambda (line)
         (cond
          ((string-prefix? "timestamp: " line)
           (format #t "Date: ~a\n"
                   (substring line (string-length "timestamp: "))))
          ((string-prefix? "message: " line)
           (format #t "Message: ~a\n"
                   (substring line (string-length "message: "))))))
       lines)
      (display "Files:\n")
      (let ((sorted-files (sort files (lambda (a b) (string<? (car a) (car b))))))
        (for-each
         (lambda (entry)
           (format #t "  ~a ~a\n" (car entry) (cdr entry)))
         sorted-files)))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (or (< (length args) 4)
                (not (string=? (list-ref args 2) "-m")))
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
