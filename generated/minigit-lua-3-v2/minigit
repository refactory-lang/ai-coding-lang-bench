#!/usr/bin/env lua

-- MiniGit: minimal version control system in Lua

local function file_exists(path)
    local f = io.open(path, "r")
    if f then f:close() return true end
    return false
end

local function dir_exists(path)
    local ret = os.execute('test -d "' .. path .. '"')
    return ret == true or ret == 0
end

local function read_file(path)
    local f = io.open(path, "rb")
    if not f then return nil end
    local content = f:read("*a")
    f:close()
    return content
end

local function write_file(path, content)
    local f = io.open(path, "wb")
    if not f then return false end
    f:write(content)
    f:close()
    return true
end

local function mkdir_p(path)
    os.execute('mkdir -p "' .. path .. '"')
end

local function minihash(data)
    local h = 1469598103934665603
    for i = 1, #data do
        local b = string.byte(data, i)
        h = h ~ b
        h = h * 1099511628211
    end
    return string.format("%016x", h)
end

local function read_index()
    local content = read_file(".minigit/index")
    if not content or content == "" then return {} end
    local files = {}
    for line in content:gmatch("[^\n]+") do
        table.insert(files, line)
    end
    return files
end

local function write_index(files)
    local content = ""
    for _, f in ipairs(files) do
        content = content .. f .. "\n"
    end
    write_file(".minigit/index", content)
end

local function cmd_init()
    if dir_exists(".minigit") then
        print("Repository already initialized")
        return
    end
    mkdir_p(".minigit/objects")
    mkdir_p(".minigit/commits")
    write_file(".minigit/index", "")
    write_file(".minigit/HEAD", "")
end

local function cmd_add(filename)
    if not file_exists(filename) then
        print("File not found")
        io.stdout:flush()
        os.exit(1)
    end
    local content = read_file(filename)
    local hash = minihash(content)
    write_file(".minigit/objects/" .. hash, content)
    local index = read_index()
    for _, f in ipairs(index) do
        if f == filename then return end
    end
    table.insert(index, filename)
    write_index(index)
end

local function cmd_commit(message)
    local index = read_index()
    if #index == 0 then
        print("Nothing to commit")
        io.stdout:flush()
        os.exit(1)
    end

    local head = read_file(".minigit/HEAD")
    if head then head = head:match("^%s*(.-)%s*$") end
    local parent = (head and head ~= "") and head or "NONE"

    local timestamp = os.time()

    table.sort(index)

    local commit_content = "parent: " .. parent .. "\n"
        .. "timestamp: " .. timestamp .. "\n"
        .. "message: " .. message .. "\n"
        .. "files:\n"

    for _, filename in ipairs(index) do
        local content = read_file(filename)
        local hash = minihash(content)
        commit_content = commit_content .. filename .. " " .. hash .. "\n"
    end

    local commit_hash = minihash(commit_content)
    write_file(".minigit/commits/" .. commit_hash, commit_content)
    write_file(".minigit/HEAD", commit_hash)
    write_file(".minigit/index", "")

    print("Committed " .. commit_hash)
end

local function cmd_log()
    local head = read_file(".minigit/HEAD")
    if not head then
        print("No commits")
        return
    end
    head = head:match("^%s*(.-)%s*$")
    if head == "" then
        print("No commits")
        return
    end

    local current = head
    local first = true

    while current and current ~= "" and current ~= "NONE" do
        if not first then
            io.write("\n")
        end
        first = false

        local commit_content = read_file(".minigit/commits/" .. current)
        if not commit_content then break end

        local cparent, timestamp, message
        for line in commit_content:gmatch("[^\n]+") do
            local k, v = line:match("^(%w+): (.+)$")
            if k == "parent" then cparent = v
            elseif k == "timestamp" then timestamp = v
            elseif k == "message" then message = v
            end
        end

        print("commit " .. current)
        print("Date: " .. (timestamp or ""))
        print("Message: " .. (message or ""))

        current = cparent
    end
end

local function cmd_status()
    local index = read_index()
    print("Staged files:")
    if #index == 0 then
        print("(none)")
    else
        for _, f in ipairs(index) do
            print(f)
        end
    end
end

local function parse_commit(commit_content)
    local cparent, timestamp, message
    local files = {}
    local in_files = false
    for line in commit_content:gmatch("[^\n]+") do
        if in_files then
            local fname, fhash = line:match("^(%S+) (%S+)$")
            if fname and fhash then
                files[fname] = fhash
            end
        elseif line == "files:" then
            in_files = true
        else
            local k, v = line:match("^(%w+): (.+)$")
            if k == "parent" then cparent = v
            elseif k == "timestamp" then timestamp = v
            elseif k == "message" then message = v
            end
        end
    end
    return cparent, timestamp, message, files
end

local function cmd_diff(hash1, hash2)
    local c1 = read_file(".minigit/commits/" .. hash1)
    if not c1 then
        print("Invalid commit")
        io.stdout:flush()
        os.exit(1)
    end
    local c2 = read_file(".minigit/commits/" .. hash2)
    if not c2 then
        print("Invalid commit")
        io.stdout:flush()
        os.exit(1)
    end

    local _, _, _, files1 = parse_commit(c1)
    local _, _, _, files2 = parse_commit(c2)

    local all_files = {}
    for f in pairs(files1) do all_files[f] = true end
    for f in pairs(files2) do all_files[f] = true end

    local sorted = {}
    for f in pairs(all_files) do table.insert(sorted, f) end
    table.sort(sorted)

    for _, f in ipairs(sorted) do
        if not files1[f] and files2[f] then
            print("Added: " .. f)
        elseif files1[f] and not files2[f] then
            print("Removed: " .. f)
        elseif files1[f] ~= files2[f] then
            print("Modified: " .. f)
        end
    end
end

local function cmd_checkout(commit_hash)
    local commit_content = read_file(".minigit/commits/" .. commit_hash)
    if not commit_content then
        print("Invalid commit")
        io.stdout:flush()
        os.exit(1)
    end

    local _, _, _, files = parse_commit(commit_content)

    for fname, blob_hash in pairs(files) do
        local blob = read_file(".minigit/objects/" .. blob_hash)
        if blob then
            write_file(fname, blob)
        end
    end

    write_file(".minigit/HEAD", commit_hash)
    write_file(".minigit/index", "")

    print("Checked out " .. commit_hash)
end

local function cmd_reset(commit_hash)
    local commit_content = read_file(".minigit/commits/" .. commit_hash)
    if not commit_content then
        print("Invalid commit")
        io.stdout:flush()
        os.exit(1)
    end

    write_file(".minigit/HEAD", commit_hash)
    write_file(".minigit/index", "")

    print("Reset to " .. commit_hash)
end

local function cmd_rm(filename)
    local index = read_index()
    local found = false
    local new_index = {}
    for _, f in ipairs(index) do
        if f == filename then
            found = true
        else
            table.insert(new_index, f)
        end
    end
    if not found then
        print("File not in index")
        io.stdout:flush()
        os.exit(1)
    end
    write_index(new_index)
end

local function cmd_show(commit_hash)
    local commit_content = read_file(".minigit/commits/" .. commit_hash)
    if not commit_content then
        print("Invalid commit")
        io.stdout:flush()
        os.exit(1)
    end

    local cparent, timestamp, message, files = parse_commit(commit_content)

    print("commit " .. commit_hash)
    print("Date: " .. (timestamp or ""))
    print("Message: " .. (message or ""))
    print("Files:")

    local sorted = {}
    for f in pairs(files) do table.insert(sorted, f) end
    table.sort(sorted)

    for _, f in ipairs(sorted) do
        print("  " .. f .. " " .. files[f])
    end
end

-- Main
local command = arg[1]

if not command then
    io.stderr:write("Usage: minigit <command>\n")
    os.exit(1)
end

if command == "init" then
    cmd_init()
elseif command == "add" then
    if not arg[2] then
        io.stderr:write("Usage: minigit add <file>\n")
        os.exit(1)
    end
    cmd_add(arg[2])
elseif command == "commit" then
    if arg[2] ~= "-m" or not arg[3] then
        io.stderr:write("Usage: minigit commit -m <message>\n")
        os.exit(1)
    end
    cmd_commit(arg[3])
elseif command == "status" then
    cmd_status()
elseif command == "log" then
    cmd_log()
elseif command == "diff" then
    if not arg[2] or not arg[3] then
        io.stderr:write("Usage: minigit diff <commit1> <commit2>\n")
        os.exit(1)
    end
    cmd_diff(arg[2], arg[3])
elseif command == "checkout" then
    if not arg[2] then
        io.stderr:write("Usage: minigit checkout <commit_hash>\n")
        os.exit(1)
    end
    cmd_checkout(arg[2])
elseif command == "reset" then
    if not arg[2] then
        io.stderr:write("Usage: minigit reset <commit_hash>\n")
        os.exit(1)
    end
    cmd_reset(arg[2])
elseif command == "rm" then
    if not arg[2] then
        io.stderr:write("Usage: minigit rm <file>\n")
        os.exit(1)
    end
    cmd_rm(arg[2])
elseif command == "show" then
    if not arg[2] then
        io.stderr:write("Usage: minigit show <commit_hash>\n")
        os.exit(1)
    end
    cmd_show(arg[2])
else
    io.stderr:write("Unknown command: " .. command .. "\n")
    os.exit(1)
end
