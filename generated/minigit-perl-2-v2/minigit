#!/usr/bin/env perl
use strict;
use warnings;
use File::Path qw(make_path);

my $MGDIR = ".minigit";

sub minihash {
    my ($data) = @_;
    use integer;
    my $h = 1469598103934665603;
    for my $b (unpack("C*", $data)) {
        $h ^= $b;
        $h *= 1099511628211;
    }
    no integer;
    return sprintf("%016x", $h);
}

sub read_file_raw {
    my ($path) = @_;
    open(my $fh, '<:raw', $path) or die "Cannot open $path: $!\n";
    local $/;
    my $content = <$fh>;
    close($fh);
    return $content;
}

sub write_file {
    my ($path, $content) = @_;
    open(my $fh, '>', $path) or die "Cannot write $path: $!\n";
    print $fh $content;
    close($fh);
}

sub read_lines {
    my ($path) = @_;
    return () unless -f $path;
    open(my $fh, '<', $path) or die "Cannot open $path: $!\n";
    my @lines = <$fh>;
    close($fh);
    chomp @lines;
    return grep { $_ ne '' } @lines;
}

sub cmd_init {
    if (-d $MGDIR) {
        print "Repository already initialized\n";
        return;
    }
    make_path("$MGDIR/objects", "$MGDIR/commits");
    write_file("$MGDIR/index", "");
    write_file("$MGDIR/HEAD", "");
}

sub cmd_add {
    my ($file) = @_;
    unless (defined $file && -f $file) {
        print "File not found\n";
        exit 1;
    }
    my $content = read_file_raw($file);
    my $hash = minihash($content);

    open(my $fh, '>:raw', "$MGDIR/objects/$hash") or die;
    print $fh $content;
    close($fh);

    my @index = read_lines("$MGDIR/index");
    unless (grep { $_ eq $file } @index) {
        push @index, $file;
        write_file("$MGDIR/index", join("\n", @index) . "\n");
    }
}

sub cmd_commit {
    my ($message) = @_;
    my @index = read_lines("$MGDIR/index");

    if (!@index) {
        print "Nothing to commit\n";
        exit 1;
    }

    my $head = "";
    if (-f "$MGDIR/HEAD") {
        open(my $fh, '<', "$MGDIR/HEAD") or die;
        $head = <$fh> // "";
        close($fh);
        chomp $head;
    }
    my $parent = $head eq "" ? "NONE" : $head;
    my $timestamp = time();

    my @sorted = sort @index;
    my @file_entries;
    for my $f (@sorted) {
        my $content = read_file_raw($f);
        my $hash = minihash($content);
        push @file_entries, "$f $hash";
    }

    my $commit_content = "parent: $parent\n";
    $commit_content .= "timestamp: $timestamp\n";
    $commit_content .= "message: $message\n";
    $commit_content .= "files:\n";
    for my $entry (@file_entries) {
        $commit_content .= "$entry\n";
    }

    my $commit_hash = minihash($commit_content);
    write_file("$MGDIR/commits/$commit_hash", $commit_content);
    write_file("$MGDIR/HEAD", $commit_hash);
    write_file("$MGDIR/index", "");
    print "Committed $commit_hash\n";
}

sub cmd_log {
    my $current = "";
    if (-f "$MGDIR/HEAD") {
        open(my $fh, '<', "$MGDIR/HEAD") or die;
        $current = <$fh> // "";
        close($fh);
        chomp $current;
    }

    if ($current eq "") {
        print "No commits\n";
        return;
    }

    my $first = 1;
    while ($current ne "" && $current ne "NONE") {
        print "\n" unless $first;
        $first = 0;

        my @lines = read_lines("$MGDIR/commits/$current");
        my ($par, $ts, $msg);
        for my $line (@lines) {
            if ($line =~ /^parent: (.+)$/) { $par = $1; }
            elsif ($line =~ /^timestamp: (.+)$/) { $ts = $1; }
            elsif ($line =~ /^message: (.+)$/) { $msg = $1; }
        }

        print "commit $current\n";
        print "Date: $ts\n";
        print "Message: $msg\n";
        $current = $par // "NONE";
    }
}

sub cmd_status {
    my @index = read_lines("$MGDIR/index");
    print "Staged files:\n";
    if (@index) {
        for my $f (@index) {
            print "$f\n";
        }
    } else {
        print "(none)\n";
    }
}

sub parse_commit {
    my ($hash) = @_;
    my $path = "$MGDIR/commits/$hash";
    return undef unless -f $path;
    my @lines = read_lines($path);
    my %info;
    my @files;
    my $in_files = 0;
    for my $line (@lines) {
        if ($in_files) {
            if ($line =~ /^(\S+)\s+(\S+)$/) {
                push @files, [$1, $2];
            }
        } elsif ($line =~ /^parent: (.+)$/) {
            $info{parent} = $1;
        } elsif ($line =~ /^timestamp: (.+)$/) {
            $info{timestamp} = $1;
        } elsif ($line =~ /^message: (.+)$/) {
            $info{message} = $1;
        } elsif ($line eq "files:") {
            $in_files = 1;
        }
    }
    $info{files} = \@files;
    return \%info;
}

sub cmd_diff {
    my ($hash1, $hash2) = @_;
    my $c1 = parse_commit($hash1);
    my $c2 = parse_commit($hash2);
    unless ($c1 && $c2) {
        print "Invalid commit\n";
        exit 1;
    }
    my %files1;
    for my $f (@{$c1->{files}}) {
        $files1{$f->[0]} = $f->[1];
    }
    my %files2;
    for my $f (@{$c2->{files}}) {
        $files2{$f->[0]} = $f->[1];
    }
    my %all_files;
    $all_files{$_} = 1 for keys %files1;
    $all_files{$_} = 1 for keys %files2;
    for my $name (sort keys %all_files) {
        my $in1 = exists $files1{$name};
        my $in2 = exists $files2{$name};
        if ($in1 && $in2) {
            if ($files1{$name} ne $files2{$name}) {
                print "Modified: $name\n";
            }
        } elsif ($in1 && !$in2) {
            print "Removed: $name\n";
        } else {
            print "Added: $name\n";
        }
    }
}

sub cmd_checkout {
    my ($hash) = @_;
    my $c = parse_commit($hash);
    unless ($c) {
        print "Invalid commit\n";
        exit 1;
    }
    for my $f (@{$c->{files}}) {
        my ($name, $blob) = @$f;
        my $content = read_file_raw("$MGDIR/objects/$blob");
        open(my $fh, '>:raw', $name) or die "Cannot write $name: $!\n";
        print $fh $content;
        close($fh);
    }
    write_file("$MGDIR/HEAD", $hash);
    write_file("$MGDIR/index", "");
    print "Checked out $hash\n";
}

sub cmd_reset {
    my ($hash) = @_;
    unless (-f "$MGDIR/commits/$hash") {
        print "Invalid commit\n";
        exit 1;
    }
    write_file("$MGDIR/HEAD", $hash);
    write_file("$MGDIR/index", "");
    print "Reset to $hash\n";
}

sub cmd_rm {
    my ($file) = @_;
    my @index = read_lines("$MGDIR/index");
    unless (grep { $_ eq $file } @index) {
        print "File not in index\n";
        exit 1;
    }
    @index = grep { $_ ne $file } @index;
    if (@index) {
        write_file("$MGDIR/index", join("\n", @index) . "\n");
    } else {
        write_file("$MGDIR/index", "");
    }
}

sub cmd_show {
    my ($hash) = @_;
    my $c = parse_commit($hash);
    unless ($c) {
        print "Invalid commit\n";
        exit 1;
    }
    print "commit $hash\n";
    print "Date: $c->{timestamp}\n";
    print "Message: $c->{message}\n";
    print "Files:\n";
    for my $f (sort { $a->[0] cmp $b->[0] } @{$c->{files}}) {
        print "  $f->[0] $f->[1]\n";
    }
}

my $cmd = shift @ARGV // "";

if ($cmd eq "init") {
    cmd_init();
} elsif ($cmd eq "add") {
    cmd_add(shift @ARGV);
} elsif ($cmd eq "commit") {
    shift @ARGV;  # skip -m
    cmd_commit(shift @ARGV);
} elsif ($cmd eq "log") {
    cmd_log();
} elsif ($cmd eq "status") {
    cmd_status();
} elsif ($cmd eq "diff") {
    cmd_diff(shift @ARGV, shift @ARGV);
} elsif ($cmd eq "checkout") {
    cmd_checkout(shift @ARGV);
} elsif ($cmd eq "reset") {
    cmd_reset(shift @ARGV);
} elsif ($cmd eq "rm") {
    cmd_rm(shift @ARGV);
} elsif ($cmd eq "show") {
    cmd_show(shift @ARGV);
} else {
    print "Usage: minigit <command>\n";
    exit 1;
}
