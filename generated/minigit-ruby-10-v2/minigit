#!/usr/bin/env ruby

require 'fileutils'

MINIGIT_DIR = '.minigit'
OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects')
COMMITS_DIR = File.join(MINIGIT_DIR, 'commits')
INDEX_FILE  = File.join(MINIGIT_DIR, 'index')
HEAD_FILE   = File.join(MINIGIT_DIR, 'HEAD')

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?(MINIGIT_DIR)
    puts "Repository already initialized"
    return
  end
  FileUtils.mkdir_p(OBJECTS_DIR)
  FileUtils.mkdir_p(COMMITS_DIR)
  File.write(INDEX_FILE, '')
  File.write(HEAD_FILE, '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts "File not found"
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(File.join(OBJECTS_DIR, hash), content)

  index_entries = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  unless index_entries.include?(filename)
    index_entries << filename
    File.write(INDEX_FILE, index_entries.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index_entries = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  if index_entries.empty?
    puts "Nothing to commit"
    exit 1
  end

  head = File.exist?(HEAD_FILE) ? File.read(HEAD_FILE).strip : ''
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  files_sorted = index_entries.sort
  file_lines = files_sorted.map do |f|
    content = File.binread(f)
    blob_hash = minihash(content)
    "#{f} #{blob_hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_lines.join("\n")}\n"

  commit_hash = minihash(commit_content)
  File.write(File.join(COMMITS_DIR, commit_hash), commit_content)
  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')

  puts "Committed #{commit_hash}"
end

def cmd_status
  index_entries = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  puts "Staged files:"
  if index_entries.empty?
    puts "(none)"
  else
    index_entries.each { |f| puts f }
  end
end

def cmd_log
  head = File.exist?(HEAD_FILE) ? File.read(HEAD_FILE).strip : ''
  if head.empty?
    puts "No commits"
    return
  end

  current = head
  while current && current != 'NONE' && !current.empty?
    commit_file = File.join(COMMITS_DIR, current)
    break unless File.exist?(commit_file)
    content = File.read(commit_file)

    timestamp = nil
    message = nil
    content.each_line do |line|
      if line.start_with?('timestamp: ')
        timestamp = line.strip.sub('timestamp: ', '')
      elsif line.start_with?('message: ')
        message = line.strip.sub('message: ', '')
      end
    end

    puts "commit #{current}"
    puts "Date: #{timestamp}"
    puts "Message: #{message}"
    puts ""

    parent = nil
    content.each_line do |line|
      if line.start_with?('parent: ')
        parent = line.strip.sub('parent: ', '')
        break
      end
    end
    current = parent
  end
end

def parse_commit_files(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end
  content = File.read(commit_file)
  files = {}
  in_files = false
  content.each_line do |line|
    if line.strip == 'files:'
      in_files = true
      next
    end
    if in_files && !line.strip.empty?
      parts = line.strip.split(' ', 2)
      files[parts[0]] = parts[1]
    end
  end
  files
end

def parse_commit(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end
  content = File.read(commit_file)
  info = {}
  content.each_line do |line|
    if line.start_with?('timestamp: ')
      info[:timestamp] = line.strip.sub('timestamp: ', '')
    elsif line.start_with?('message: ')
      info[:message] = line.strip.sub('message: ', '')
    elsif line.start_with?('parent: ')
      info[:parent] = line.strip.sub('parent: ', '')
    end
  end
  info[:files] = parse_commit_files(commit_hash)
  info
end

def cmd_diff(hash1, hash2)
  files1 = parse_commit_files(hash1)
  files2 = parse_commit_files(hash2)

  all_files = (files1.keys + files2.keys).uniq.sort
  all_files.each do |f|
    if files1[f].nil?
      puts "Added: #{f}"
    elsif files2[f].nil?
      puts "Removed: #{f}"
    elsif files1[f] != files2[f]
      puts "Modified: #{f}"
    end
  end
end

def cmd_checkout(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end

  files = parse_commit_files(commit_hash)
  files.each do |filename, blob_hash|
    blob_path = File.join(OBJECTS_DIR, blob_hash)
    content = File.binread(blob_path)
    File.binwrite(filename, content)
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Checked out #{commit_hash}"
end

def cmd_reset(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Reset to #{commit_hash}"
end

def cmd_rm(filename)
  index_entries = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  unless index_entries.include?(filename)
    puts "File not in index"
    exit 1
  end
  index_entries.delete(filename)
  File.write(INDEX_FILE, index_entries.empty? ? '' : index_entries.join("\n") + "\n")
end

def cmd_show(commit_hash)
  info = parse_commit(commit_hash)
  files = info[:files]

  puts "commit #{commit_hash}"
  puts "Date: #{info[:timestamp]}"
  puts "Message: #{info[:message]}"
  puts "Files:"
  files.keys.sort.each do |f|
    puts "  #{f} #{files[f]}"
  end
end

command = ARGV[0]
case command
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  end
when 'status'
  cmd_status
when 'log'
  cmd_log
when 'diff'
  cmd_diff(ARGV[1], ARGV[2])
when 'checkout'
  cmd_checkout(ARGV[1])
when 'reset'
  cmd_reset(ARGV[1])
when 'rm'
  cmd_rm(ARGV[1])
when 'show'
  cmd_show(ARGV[1])
end
