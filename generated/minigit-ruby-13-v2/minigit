#!/usr/bin/env ruby

MINIGIT_DIR = '.minigit'
OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects')
COMMITS_DIR = File.join(MINIGIT_DIR, 'commits')
INDEX_FILE  = File.join(MINIGIT_DIR, 'index')
HEAD_FILE   = File.join(MINIGIT_DIR, 'HEAD')

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?(MINIGIT_DIR)
    puts "Repository already initialized"
    return
  end
  Dir.mkdir(MINIGIT_DIR)
  Dir.mkdir(OBJECTS_DIR)
  Dir.mkdir(COMMITS_DIR)
  File.write(INDEX_FILE, '')
  File.write(HEAD_FILE, '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts "File not found"
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(File.join(OBJECTS_DIR, hash), content)

  index = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  unless index.include?(filename)
    index << filename
    File.write(INDEX_FILE, index.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  if index.empty?
    puts "Nothing to commit"
    exit 1
  end

  parent = File.read(HEAD_FILE).strip
  parent = parent.empty? ? 'NONE' : parent
  timestamp = Time.now.to_i

  files_sorted = index.sort.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{files_sorted.join("\n")}\n"

  commit_hash = minihash(commit_content.b)
  File.write(File.join(COMMITS_DIR, commit_hash), commit_content)
  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Committed #{commit_hash}"
end

def cmd_status
  index = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  puts "Staged files:"
  if index.empty?
    puts "(none)"
  else
    index.each { |f| puts f }
  end
end

def cmd_log
  head = File.read(HEAD_FILE).strip
  if head.empty?
    puts "No commits"
    return
  end

  current = head
  while current && current != 'NONE' && !current.empty?
    commit_file = File.join(COMMITS_DIR, current)
    break unless File.exist?(commit_file)
    content = File.read(commit_file)

    timestamp = nil
    message = nil
    content.each_line do |line|
      line.chomp!
      if line.start_with?('timestamp: ')
        timestamp = line.sub('timestamp: ', '')
      elsif line.start_with?('message: ')
        message = line.sub('message: ', '')
      end
    end

    puts "commit #{current}"
    puts "Date: #{timestamp}"
    puts "Message: #{message}"
    puts ""

    parent_line = content.lines.find { |l| l.start_with?('parent: ') }
    current = parent_line ? parent_line.strip.sub('parent: ', '') : nil
  end
end

def parse_commit_files(content)
  files = {}
  in_files = false
  content.each_line do |line|
    line.chomp!
    if line == 'files:'
      in_files = true
    elsif in_files && !line.empty?
      parts = line.split(' ', 2)
      files[parts[0]] = parts[1] if parts.length == 2
    end
  end
  files
end

def cmd_diff(hash1, hash2)
  commit1_file = File.join(COMMITS_DIR, hash1)
  commit2_file = File.join(COMMITS_DIR, hash2)

  unless File.exist?(commit1_file)
    puts "Invalid commit"
    exit 1
  end
  unless File.exist?(commit2_file)
    puts "Invalid commit"
    exit 1
  end

  files1 = parse_commit_files(File.read(commit1_file))
  files2 = parse_commit_files(File.read(commit2_file))

  all_files = (files1.keys + files2.keys).uniq.sort

  all_files.each do |f|
    if files1.key?(f) && !files2.key?(f)
      puts "Removed: #{f}"
    elsif !files1.key?(f) && files2.key?(f)
      puts "Added: #{f}"
    elsif files1[f] != files2[f]
      puts "Modified: #{f}"
    end
  end
end

def cmd_checkout(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end

  files = parse_commit_files(File.read(commit_file))
  files.each do |filename, blob_hash|
    blob_path = File.join(OBJECTS_DIR, blob_hash)
    File.binwrite(filename, File.binread(blob_path))
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Checked out #{commit_hash}"
end

def cmd_reset(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end

  File.write(HEAD_FILE, commit_hash)
  File.write(INDEX_FILE, '')
  puts "Reset to #{commit_hash}"
end

def cmd_rm(filename)
  index = File.exist?(INDEX_FILE) ? File.read(INDEX_FILE).split("\n").reject(&:empty?) : []
  unless index.include?(filename)
    puts "File not in index"
    exit 1
  end
  index.delete(filename)
  File.write(INDEX_FILE, index.empty? ? '' : index.join("\n") + "\n")
end

def cmd_show(commit_hash)
  commit_file = File.join(COMMITS_DIR, commit_hash)
  unless File.exist?(commit_file)
    puts "Invalid commit"
    exit 1
  end

  content = File.read(commit_file)
  timestamp = nil
  message = nil
  content.each_line do |line|
    line.chomp!
    if line.start_with?('timestamp: ')
      timestamp = line.sub('timestamp: ', '')
    elsif line.start_with?('message: ')
      message = line.sub('message: ', '')
    end
  end

  files = parse_commit_files(content)

  puts "commit #{commit_hash}"
  puts "Date: #{timestamp}"
  puts "Message: #{message}"
  puts "Files:"
  files.keys.sort.each do |f|
    puts "  #{f} #{files[f]}"
  end
end

command = ARGV[0]
case command
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  else
    puts "Usage: minigit commit -m \"message\""
    exit 1
  end
when 'status'
  cmd_status
when 'log'
  cmd_log
when 'diff'
  cmd_diff(ARGV[1], ARGV[2])
when 'checkout'
  cmd_checkout(ARGV[1])
when 'reset'
  cmd_reset(ARGV[1])
when 'rm'
  cmd_rm(ARGV[1])
when 'show'
  cmd_show(ARGV[1])
else
  puts "Unknown command: #{command}"
  exit 1
end
