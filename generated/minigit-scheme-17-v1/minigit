#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (rnrs bytevectors))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex output
(define (minihash bv)
  (let ((len (bytevector-length bv)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h (expt 2 64)))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) (expt 2 64))))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-file path "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (read-file-text path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-text path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((content (read-file-text path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (begin
        (display "Repository already initialized\n"))
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-text ".minigit/index" "")
        (write-file-text ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    ;; Store blob
    (let ((blob-path (string-append ".minigit/objects/" hash)))
      (unless (file-exists? blob-path)
        (copy-file-binary filename blob-path)))
    ;; Update index
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((lines (read-lines ".minigit/index")))
    (when (null? lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (read-file-text ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (number->string (current-time)))
           (sorted-files (sort lines string<?))
           ;; Build file entries with their blob hashes
           (file-entries
            (map (lambda (f)
                   (let* ((hash (minihash-file f)))
                     (string-append f " " hash)))
                 sorted-files))
           ;; Build commit content
           (commit-content
            (string-append
             "parent: " parent "\n"
             "timestamp: " timestamp "\n"
             "message: " message "\n"
             "files:\n"
             (string-join file-entries "\n")
             "\n"))
           (commit-hash (minihash-string commit-content)))
      ;; Write commit file
      (write-file-text (string-append ".minigit/commits/" commit-hash) commit-content)
      ;; Update HEAD
      (write-file-text ".minigit/HEAD" commit-hash)
      ;; Clear index
      (write-file-text ".minigit/index" "")
      ;; Print
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-text ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content) (first #t))
          (when (and (not (string=? hash "NONE")) (not (string=? hash "")))
            (let* ((commit-path (string-append ".minigit/commits/" hash))
                   (content (read-file-text commit-path))
                   (lines (string-split content #\newline)))
              ;; Parse parent, timestamp, message
              (let ((parent "NONE")
                    (timestamp "0")
                    (msg ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! msg (substring line 9)))))
                 lines)
                (unless first (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" msg)
                (loop parent #f))))))))

;;; Main dispatch
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init")
      (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (or (< (length args) 4)
                (not (string=? (list-ref args 2) "-m")))
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "log")
      (cmd-log))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
