#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 match)
             (rnrs bytevectors))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-input-file path #:binary #t))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (read-file-content path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-content path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (copy-file-binary src dst)
  (let* ((in (open-input-file src #:binary #t))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-output-file dst #:binary #t)))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

(define (read-lines path)
  (let ((content (read-file-content path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-content ".minigit/index" "")
        (write-file-content ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    (copy-file-binary filename (string-append ".minigit/objects/" hash))
    ;; Add to index if not already present
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((index-lines (read-lines ".minigit/index")))
    (when (null? index-lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (read-file-content ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (car (gettimeofday)))
           (sorted-files (sort index-lines string<?))
           (file-entries
            (string-join
             (map (lambda (fname)
                    (let* ((data (let* ((p (open-input-file fname #:binary #t))
                                        (d (get-bytevector-all p)))
                                   (close-port p)
                                   d))
                           (hash (if (eof-object? data)
                                     (minihash (make-bytevector 0))
                                     (minihash data))))
                      (string-append fname " " hash)))
                  sorted-files)
             "\n"))
           (commit-content
            (string-append "parent: " parent "\n"
                           "timestamp: " (number->string timestamp) "\n"
                           "message: " message "\n"
                           "files:\n"
                           file-entries "\n"))
           (commit-hash (minihash-string commit-content)))
      (write-file-content (string-append ".minigit/commits/" commit-hash)
                          commit-content)
      (write-file-content ".minigit/HEAD" commit-hash)
      (write-file-content ".minigit/index" "")
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-content ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content) (first #t))
          (unless (or (string=? hash "") (string=? hash "NONE"))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-content path))
                   (lines (string-split content #\newline)))
              ;; Parse parent, timestamp, message
              (let ((parent "NONE")
                    (timestamp "")
                    (msg ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! msg (substring line 9)))))
                 lines)
                (unless first (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" msg)
                (loop parent #f))))))))

;;; Main dispatch
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (< (length args) 4)
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "log") (cmd-log))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
