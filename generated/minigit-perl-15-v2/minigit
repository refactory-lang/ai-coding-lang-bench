#!/usr/bin/env perl
use strict;
use warnings;
no warnings 'portable';
use File::Path qw(make_path);
use File::Basename;
use Cwd qw(getcwd);

my $MINIGIT_DIR = ".minigit";
my $OBJECTS_DIR = "$MINIGIT_DIR/objects";
my $COMMITS_DIR = "$MINIGIT_DIR/commits";
my $INDEX_FILE  = "$MINIGIT_DIR/index";
my $HEAD_FILE   = "$MINIGIT_DIR/HEAD";

sub minihash {
    my ($data) = @_;
    # Use Math::BigInt for proper 64-bit unsigned arithmetic
    # But we can use regular integers if perl supports 64-bit
    # We'll do manual modular arithmetic
    my $h = 1469598103934665603;
    my $mod = 2**64;
    my $prime = 1099511628211;

    for my $b (unpack("C*", $data)) {
        $h ^= $b;
        # Multiply with mod 2^64 using no_unsigned_overflow
        # Perl may have 64-bit integers; use modular math
        use integer;
        $h = _mul_mod64($h, $prime);
        no integer;
    }
    return sprintf("%016x", $h & 0xFFFFFFFFFFFFFFFF);
}

sub _mul_mod64 {
    my ($a, $b) = @_;
    # For 64-bit perl, we can try direct multiplication
    # but overflow might wrap. Let's use split multiplication.
    # Split b into high and low 32 bits
    my $b_low  = $b & 0xFFFFFFFF;
    my $b_high = ($b >> 32) & 0xFFFFFFFF;
    my $a_low  = $a & 0xFFFFFFFF;
    my $a_high = ($a >> 32) & 0xFFFFFFFF;

    # result = (a_low * b_low) + ((a_low * b_high + a_high * b_low) << 32)
    # all mod 2^64
    my $r1 = $a_low * $b_low;
    my $r2 = ($a_low * $b_high + $a_high * $b_low) & 0xFFFFFFFF;
    my $result = ($r1 + ($r2 << 32)) & 0xFFFFFFFFFFFFFFFF;
    return $result;
}

sub read_file {
    my ($path) = @_;
    open my $fh, '<', $path or return '';
    local $/;
    my $content = <$fh>;
    close $fh;
    return defined $content ? $content : '';
}

sub read_file_binary {
    my ($path) = @_;
    open my $fh, '<:raw', $path or return '';
    local $/;
    my $content = <$fh>;
    close $fh;
    return defined $content ? $content : '';
}

sub write_file {
    my ($path, $content) = @_;
    open my $fh, '>', $path or die "Cannot write $path: $!\n";
    print $fh $content;
    close $fh;
}

sub write_file_binary {
    my ($path, $content) = @_;
    open my $fh, '>:raw', $path or die "Cannot write $path: $!\n";
    print $fh $content;
    close $fh;
}

sub cmd_init {
    if (-d $MINIGIT_DIR) {
        print "Repository already initialized\n";
        return;
    }
    make_path($OBJECTS_DIR);
    make_path($COMMITS_DIR);
    write_file($INDEX_FILE, '');
    write_file($HEAD_FILE, '');
}

sub cmd_add {
    my ($file) = @_;
    unless (defined $file && -e $file) {
        print "File not found\n";
        exit 1;
    }

    my $content = read_file_binary($file);
    my $hash = minihash($content);

    write_file_binary("$OBJECTS_DIR/$hash", $content);

    # Read current index
    my $index_content = read_file($INDEX_FILE);
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    unless (grep { $_ eq $file } @entries) {
        push @entries, $file;
        write_file($INDEX_FILE, join("\n", @entries) . "\n");
    }
}

sub cmd_commit {
    my ($message) = @_;

    my $index_content = read_file($INDEX_FILE);
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    if (@entries == 0) {
        print "Nothing to commit\n";
        exit 1;
    }

    # Sort filenames lexicographically
    @entries = sort @entries;

    # Get parent
    my $head = read_file($HEAD_FILE);
    chomp $head if defined $head;
    my $parent = (defined $head && $head ne '') ? $head : 'NONE';

    # Get timestamp
    my $timestamp = time();

    # Build file list with blob hashes
    my @file_lines;
    for my $file (@entries) {
        my $content = read_file_binary($file);
        my $hash = minihash($content);
        push @file_lines, "$file $hash";
    }

    # Build commit content
    my $commit_content = "parent: $parent\n";
    $commit_content .= "timestamp: $timestamp\n";
    $commit_content .= "message: $message\n";
    $commit_content .= "files:\n";
    $commit_content .= join("\n", @file_lines) . "\n";

    my $commit_hash = minihash($commit_content);

    write_file("$COMMITS_DIR/$commit_hash", $commit_content);
    write_file($HEAD_FILE, $commit_hash);
    write_file($INDEX_FILE, '');

    print "Committed $commit_hash\n";
}

sub cmd_status {
    my $index_content = read_file($INDEX_FILE);
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    print "Staged files:\n";
    if (@entries == 0) {
        print "(none)\n";
    } else {
        for my $entry (@entries) {
            print "$entry\n";
        }
    }
}

sub cmd_log {
    my $head = read_file($HEAD_FILE);
    chomp $head if defined $head;

    if (!defined $head || $head eq '') {
        print "No commits\n";
        return;
    }

    my $current = $head;
    while ($current ne '' && $current ne 'NONE') {
        my $commit_path = "$COMMITS_DIR/$current";
        last unless -f $commit_path;

        my $content = read_file($commit_path);
        my ($parent, $timestamp, $message);

        for my $line (split(/\n/, $content)) {
            if ($line =~ /^parent: (.*)/) {
                $parent = $1;
            } elsif ($line =~ /^timestamp: (.*)/) {
                $timestamp = $1;
            } elsif ($line =~ /^message: (.*)/) {
                $message = $1;
            }
        }

        print "commit $current\n";
        print "Date: $timestamp\n";
        print "Message: $message\n";
        print "\n";

        $current = (defined $parent && $parent ne 'NONE') ? $parent : '';
    }
}

sub parse_commit_files {
    my ($commit_hash) = @_;
    my $commit_path = "$COMMITS_DIR/$commit_hash";
    unless (-f $commit_path) {
        return undef;
    }
    my $content = read_file($commit_path);
    my %files;
    my $in_files = 0;
    for my $line (split(/\n/, $content)) {
        if ($line eq 'files:') {
            $in_files = 1;
            next;
        }
        if ($in_files && $line =~ /^(\S+)\s+(\S+)$/) {
            $files{$1} = $2;
        }
    }
    return \%files;
}

sub cmd_diff {
    my ($commit1, $commit2) = @_;

    my $files1 = parse_commit_files($commit1);
    unless (defined $files1) {
        print "Invalid commit\n";
        exit 1;
    }
    my $files2 = parse_commit_files($commit2);
    unless (defined $files2) {
        print "Invalid commit\n";
        exit 1;
    }

    my %all_files;
    $all_files{$_} = 1 for keys %$files1;
    $all_files{$_} = 1 for keys %$files2;

    for my $file (sort keys %all_files) {
        my $h1 = $files1->{$file};
        my $h2 = $files2->{$file};
        if (!defined $h1 && defined $h2) {
            print "Added: $file\n";
        } elsif (defined $h1 && !defined $h2) {
            print "Removed: $file\n";
        } elsif ($h1 ne $h2) {
            print "Modified: $file\n";
        }
    }
}

sub cmd_checkout {
    my ($commit_hash) = @_;
    my $commit_path = "$COMMITS_DIR/$commit_hash";
    unless (-f $commit_path) {
        print "Invalid commit\n";
        exit 1;
    }

    my $files = parse_commit_files($commit_hash);
    for my $file (sort keys %$files) {
        my $blob_hash = $files->{$file};
        my $blob_content = read_file_binary("$OBJECTS_DIR/$blob_hash");
        write_file_binary($file, $blob_content);
    }

    write_file($HEAD_FILE, $commit_hash);
    write_file($INDEX_FILE, '');

    print "Checked out $commit_hash\n";
}

sub cmd_reset {
    my ($commit_hash) = @_;
    my $commit_path = "$COMMITS_DIR/$commit_hash";
    unless (-f $commit_path) {
        print "Invalid commit\n";
        exit 1;
    }

    write_file($HEAD_FILE, $commit_hash);
    write_file($INDEX_FILE, '');

    print "Reset to $commit_hash\n";
}

sub cmd_rm {
    my ($file) = @_;
    my $index_content = read_file($INDEX_FILE);
    my @entries = grep { $_ ne '' } split(/\n/, $index_content);

    unless (grep { $_ eq $file } @entries) {
        print "File not in index\n";
        exit 1;
    }

    @entries = grep { $_ ne $file } @entries;
    if (@entries) {
        write_file($INDEX_FILE, join("\n", @entries) . "\n");
    } else {
        write_file($INDEX_FILE, '');
    }
}

sub cmd_show {
    my ($commit_hash) = @_;
    my $commit_path = "$COMMITS_DIR/$commit_hash";
    unless (-f $commit_path) {
        print "Invalid commit\n";
        exit 1;
    }

    my $content = read_file($commit_path);
    my ($timestamp, $message);
    my @file_lines;
    my $in_files = 0;

    for my $line (split(/\n/, $content)) {
        if ($line =~ /^timestamp: (.*)/) {
            $timestamp = $1;
        } elsif ($line =~ /^message: (.*)/) {
            $message = $1;
        } elsif ($line eq 'files:') {
            $in_files = 1;
        } elsif ($in_files && $line =~ /^(\S+)\s+(\S+)$/) {
            push @file_lines, "  $1 $2";
        }
    }

    print "commit $commit_hash\n";
    print "Date: $timestamp\n";
    print "Message: $message\n";
    print "Files:\n";
    for my $fl (sort @file_lines) {
        print "$fl\n";
    }
}

# Main
my $command = shift @ARGV;

unless (defined $command) {
    print "Usage: minigit <command>\n";
    exit 1;
}

if ($command eq 'init') {
    cmd_init();
} elsif ($command eq 'add') {
    cmd_add(shift @ARGV);
} elsif ($command eq 'commit') {
    my $flag = shift @ARGV;
    my $message = shift @ARGV;
    if (!defined $flag || $flag ne '-m' || !defined $message) {
        print "Usage: minigit commit -m \"message\"\n";
        exit 1;
    }
    cmd_commit($message);
} elsif ($command eq 'status') {
    cmd_status();
} elsif ($command eq 'log') {
    cmd_log();
} elsif ($command eq 'diff') {
    my $c1 = shift @ARGV;
    my $c2 = shift @ARGV;
    cmd_diff($c1, $c2);
} elsif ($command eq 'checkout') {
    cmd_checkout(shift @ARGV);
} elsif ($command eq 'reset') {
    cmd_reset(shift @ARGV);
} elsif ($command eq 'rm') {
    cmd_rm(shift @ARGV);
} elsif ($command eq 'show') {
    cmd_show(shift @ARGV);
} else {
    print "Unknown command: $command\n";
    exit 1;
}
