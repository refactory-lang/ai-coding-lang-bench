#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 match)
             (rnrs bytevectors))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-file filename)
  (let* ((port (open-file filename "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

;;; File helpers
(define (file-exists-regular? path)
  (and (file-exists? path)
       (eq? 'regular (stat:type (stat path)))))

(define (read-file-content path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (content (get-string-all port)))
        (close-port port)
        (if (eof-object? content) "" content))
      ""))

(define (write-file-content path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (read-lines path)
  (let ((content (read-file-content path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

(define (copy-file-binary src dst)
  (let* ((in (open-file src "rb"))
         (data (get-bytevector-all in)))
    (close-port in)
    (let ((out (open-file dst "wb")))
      (unless (eof-object? data)
        (put-bytevector out data))
      (close-port out))))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (mkdir ".minigit")
        (mkdir ".minigit/objects")
        (mkdir ".minigit/commits")
        (write-file-content ".minigit/index" "")
        (write-file-content ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists-regular? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    ;; Store blob
    (let ((objpath (string-append ".minigit/objects/" hash)))
      (unless (file-exists? objpath)
        (copy-file-binary filename objpath)))
    ;; Update index
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((index-lines (read-lines ".minigit/index")))
    (when (null? index-lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (read-file-content ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (number->string (current-time)))
           (sorted-files (sort index-lines string<?))
           ;; Build file entries: for each file, get hash of its current content
           (file-entries
            (map (lambda (f)
                   (string-append f " " (minihash-file f)))
                 sorted-files))
           (commit-content
            (string-append
             "parent: " parent "\n"
             "timestamp: " timestamp "\n"
             "message: " message "\n"
             "files:\n"
             (string-join file-entries "\n")
             "\n"))
           (commit-hash (minihash-string commit-content)))
      ;; Write commit file
      (write-file-content (string-append ".minigit/commits/" commit-hash) commit-content)
      ;; Update HEAD
      (write-file-content ".minigit/HEAD" commit-hash)
      ;; Clear index
      (write-file-content ".minigit/index" "")
      ;; Print
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-content ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content) (first? #t))
          (when (and (not (string=? hash "NONE")) (not (string=? hash "")))
            (let* ((commit-path (string-append ".minigit/commits/" hash))
                   (content (read-file-content commit-path))
                   (lines (string-split content #\newline)))
              ;; Parse parent, timestamp, message
              (let ((parent "NONE")
                    (timestamp "0")
                    (message ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! message (substring line 9)))))
                 lines)
                (unless first? (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" message)
                (loop parent #f))))))))

(define (cmd-status)
  (let ((lines (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? lines)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) lines))))

(define (parse-commit-files content)
  ;; Parse file entries from commit content (after "files:" line)
  (let* ((lines (string-split content #\newline))
         (in-files #f)
         (result '()))
    (for-each
     (lambda (line)
       (cond
        ((string=? line "files:")
         (set! in-files #t))
        (in-files
         (when (not (string=? line ""))
           (let ((parts (string-split line #\space)))
             (when (>= (length parts) 2)
               (set! result (cons (cons (car parts) (cadr parts)) result))))))))
     lines)
    (reverse result)))

(define (parse-commit content)
  ;; Returns (parent timestamp message files-alist)
  (let ((parent "NONE")
        (timestamp "0")
        (message ""))
    (let ((lines (string-split content #\newline)))
      (for-each
       (lambda (line)
         (cond
          ((string-prefix? "parent: " line)
           (set! parent (substring line 8)))
          ((string-prefix? "timestamp: " line)
           (set! timestamp (substring line 11)))
          ((string-prefix? "message: " line)
           (set! message (substring line 9)))))
       lines))
    (values parent timestamp message (parse-commit-files content))))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists? path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists? path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content1 (read-file-content path1))
           (content2 (read-file-content path2))
           (files1 (parse-commit-files content1))
           (files2 (parse-commit-files content2))
           ;; Collect all filenames
           (all-names-raw (append (map car files1) (map car files2)))
           (all-names (sort (let loop ((lst all-names-raw) (seen '()))
                              (cond
                               ((null? lst) (reverse seen))
                               ((member (car lst) seen) (loop (cdr lst) seen))
                               (else (loop (cdr lst) (cons (car lst) seen)))))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-content commit-path))
           (files (parse-commit-files content)))
      ;; Restore each file from objects
      (for-each
       (lambda (entry)
         (let* ((filename (car entry))
                (blob-hash (cdr entry))
                (obj-path (string-append ".minigit/objects/" blob-hash)))
           (copy-file-binary obj-path filename)))
       files)
      ;; Update HEAD
      (write-file-content ".minigit/HEAD" hash)
      ;; Clear index
      (write-file-content ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    ;; Update HEAD
    (write-file-content ".minigit/HEAD" hash)
    ;; Clear index
    (write-file-content ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm filename)
  (let ((lines (read-lines ".minigit/index")))
    (unless (member filename lines)
      (display "File not in index\n")
      (exit 1))
    (let ((new-lines (filter (lambda (f) (not (string=? f filename))) lines)))
      (write-file-content ".minigit/index"
                          (if (null? new-lines)
                              ""
                              (string-append (string-join new-lines "\n") "\n"))))))

(define (cmd-show hash)
  (let ((commit-path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? commit-path)
      (display "Invalid commit\n")
      (exit 1))
    (let ((content (read-file-content commit-path)))
      (call-with-values (lambda () (parse-commit content))
        (lambda (parent timestamp message files)
          (format #t "commit ~a\n" hash)
          (format #t "Date: ~a\n" timestamp)
          (format #t "Message: ~a\n" message)
          (display "Files:\n")
          (for-each
           (lambda (entry)
             (format #t "  ~a ~a\n" (car entry) (cdr entry)))
           (sort files (lambda (a b) (string<? (car a) (car b))))))))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (or (< (length args) 4)
                (not (string=? (list-ref args 2) "-m")))
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit_hash>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit_hash>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit_hash>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
