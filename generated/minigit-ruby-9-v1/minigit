#!/usr/bin/env ruby

def minihash(data)
  h = 1469598103934665603
  data.each_byte do |b|
    h ^= b
    h = (h * 1099511628211) % (2**64)
  end
  format('%016x', h)
end

def cmd_init
  if Dir.exist?('.minigit')
    puts 'Repository already initialized'
    return
  end
  Dir.mkdir('.minigit')
  Dir.mkdir('.minigit/objects')
  Dir.mkdir('.minigit/commits')
  File.write('.minigit/index', '')
  File.write('.minigit/HEAD', '')
end

def cmd_add(filename)
  unless File.exist?(filename)
    puts 'File not found'
    exit 1
  end
  content = File.binread(filename)
  hash = minihash(content)
  File.binwrite(".minigit/objects/#{hash}", content)

  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  unless entries.include?(filename)
    entries << filename
    File.write(index_path, entries.join("\n") + "\n")
  end
end

def cmd_commit(message)
  index_path = '.minigit/index'
  entries = File.read(index_path).split("\n").reject(&:empty?)
  if entries.empty?
    puts 'Nothing to commit'
    exit 1
  end

  head = File.read('.minigit/HEAD').strip
  parent = head.empty? ? 'NONE' : head
  timestamp = Time.now.to_i

  files_sorted = entries.sort
  file_lines = files_sorted.map do |f|
    content = File.binread(f)
    hash = minihash(content)
    "#{f} #{hash}"
  end

  commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage: #{message}\nfiles:\n#{file_lines.join("\n")}\n"

  commit_hash = minihash(commit_content.b)
  File.write(".minigit/commits/#{commit_hash}", commit_content)
  File.write('.minigit/HEAD', commit_hash)
  File.write(index_path, '')

  puts "Committed #{commit_hash}"
end

def cmd_log
  head = File.read('.minigit/HEAD').strip
  if head.empty?
    puts 'No commits'
    return
  end

  current = head
  first = true
  while current && current != 'NONE' && !current.empty?
    commit_file = ".minigit/commits/#{current}"
    break unless File.exist?(commit_file)

    content = File.read(commit_file)
    lines = content.split("\n")

    parent_line = lines.find { |l| l.start_with?('parent:') }
    timestamp_line = lines.find { |l| l.start_with?('timestamp:') }
    message_line = lines.find { |l| l.start_with?('message:') }

    parent = parent_line.split(' ', 2)[1].strip
    timestamp = timestamp_line.split(' ', 2)[1].strip
    message = message_line.split(' ', 2)[1].strip

    puts '' unless first
    puts "commit #{current}"
    puts "Date: #{timestamp}"
    puts "Message: #{message}"

    first = false
    current = parent
  end
end

command = ARGV[0]
case command
when 'init'
  cmd_init
when 'add'
  cmd_add(ARGV[1])
when 'commit'
  if ARGV[1] == '-m'
    cmd_commit(ARGV[2])
  end
when 'log'
  cmd_log
end
