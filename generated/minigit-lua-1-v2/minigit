#!/usr/bin/env lua

-- MiniGit: minimal version control system in Lua

local MINIGIT_DIR = ".minigit"
local OBJECTS_DIR = MINIGIT_DIR .. "/objects"
local COMMITS_DIR = MINIGIT_DIR .. "/commits"
local INDEX_FILE  = MINIGIT_DIR .. "/index"
local HEAD_FILE   = MINIGIT_DIR .. "/HEAD"

-- Utility: check if path is a directory
local function is_dir(path)
    local f = io.open(path .. "/.", "r")
    if f then f:close() return true end
    return false
end

-- Utility: check if file exists
local function file_exists(path)
    local f = io.open(path, "r")
    if f then f:close() return true end
    return false
end

-- Utility: read entire file as binary
local function read_file(path)
    local f = io.open(path, "rb")
    if not f then return nil end
    local data = f:read("*a")
    f:close()
    return data
end

-- Utility: write data to file
local function write_file(path, data)
    local f = io.open(path, "wb")
    if not f then
        io.stderr:write("Error: cannot write to " .. path .. "\n")
        os.exit(1)
    end
    f:write(data)
    f:close()
end

-- Utility: mkdir -p (simple, one level)
local function mkdir(path)
    os.execute("mkdir -p " .. path)
end

-- MiniHash: FNV-1a variant, 64-bit, 16-char hex
local function minihash(data)
    local h = 1469598103934665603 -- unsigned 64-bit init
    for i = 1, #data do
        local b = string.byte(data, i)
        h = h ~ b                           -- XOR
        h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF  -- multiply mod 2^64
    end
    return string.format("%016x", h)
end

-- Command: init
local function cmd_init()
    if is_dir(MINIGIT_DIR) then
        print("Repository already initialized")
        os.exit(0)
    end
    mkdir(OBJECTS_DIR)
    mkdir(COMMITS_DIR)
    write_file(INDEX_FILE, "")
    write_file(HEAD_FILE, "")
    os.exit(0)
end

-- Read index file, return list of filenames
local function read_index()
    local data = read_file(INDEX_FILE)
    if not data or data == "" then return {} end
    local files = {}
    for line in data:gmatch("[^\n]+") do
        if line ~= "" then
            files[#files + 1] = line
        end
    end
    return files
end

-- Write index file from list of filenames
local function write_index(files)
    if #files == 0 then
        write_file(INDEX_FILE, "")
        return
    end
    local data = table.concat(files, "\n") .. "\n"
    write_file(INDEX_FILE, data)
end

-- Command: add <file>
local function cmd_add(filename)
    if not filename then
        io.stderr:write("Usage: minigit add <file>\n")
        os.exit(1)
    end
    if not file_exists(filename) then
        print("File not found")
        os.exit(1)
    end

    local content = read_file(filename)
    local hash = minihash(content)

    -- Store blob
    write_file(OBJECTS_DIR .. "/" .. hash, content)

    -- Update index: add filename if not already present
    local index = read_index()
    local found = false
    for _, f in ipairs(index) do
        if f == filename then
            found = true
            break
        end
    end
    if not found then
        index[#index + 1] = filename
        write_index(index)
    end

    os.exit(0)
end

-- Command: commit -m "<message>"
local function cmd_commit(args)
    -- Parse -m flag
    local message = nil
    for i = 1, #args do
        if args[i] == "-m" and args[i + 1] then
            message = args[i + 1]
            break
        end
    end
    if not message then
        io.stderr:write("Usage: minigit commit -m \"<message>\"\n")
        os.exit(1)
    end

    -- Check index
    local index = read_index()
    if #index == 0 then
        print("Nothing to commit")
        os.exit(1)
    end

    -- Sort filenames
    table.sort(index)

    -- Get parent
    local head = read_file(HEAD_FILE)
    if head then head = head:match("^%s*(.-)%s*$") end  -- trim
    local parent = (head and head ~= "") and head or "NONE"

    -- Get timestamp
    local timestamp = tostring(os.time())

    -- Build file entries: filename blobhash
    local file_entries = {}
    for _, fname in ipairs(index) do
        local content = read_file(fname)
        if content then
            local hash = minihash(content)
            file_entries[#file_entries + 1] = fname .. " " .. hash
        end
    end

    -- Build commit content
    local commit_content = "parent: " .. parent .. "\n"
        .. "timestamp: " .. timestamp .. "\n"
        .. "message: " .. message .. "\n"
        .. "files:\n"
        .. table.concat(file_entries, "\n") .. "\n"

    -- Hash commit
    local commit_hash = minihash(commit_content)

    -- Write commit file
    write_file(COMMITS_DIR .. "/" .. commit_hash, commit_content)

    -- Update HEAD
    write_file(HEAD_FILE, commit_hash)

    -- Clear index
    write_file(INDEX_FILE, "")

    print("Committed " .. commit_hash)
    os.exit(0)
end

-- Command: status
local function cmd_status()
    local index = read_index()
    print("Staged files:")
    if #index == 0 then
        print("(none)")
    else
        for _, f in ipairs(index) do
            print(f)
        end
    end
    os.exit(0)
end

-- Command: log
local function cmd_log()
    local head = read_file(HEAD_FILE)
    if head then head = head:match("^%s*(.-)%s*$") end
    if not head or head == "" then
        print("No commits")
        os.exit(0)
    end

    local current = head
    local first = true
    while current and current ~= "" and current ~= "NONE" do
        local commit_data = read_file(COMMITS_DIR .. "/" .. current)
        if not commit_data then break end

        if not first then
            print("")
        end
        first = false

        -- Parse commit
        local p = commit_data:match("parent: ([^\n]+)")
        local ts = commit_data:match("timestamp: ([^\n]+)")
        local msg = commit_data:match("message: ([^\n]+)")

        print("commit " .. current)
        print("Date: " .. ts)
        print("Message: " .. msg)

        current = p
        if current == "NONE" then break end
    end

    os.exit(0)
end

-- Parse files section from commit data, returns table {filename = blobhash}
local function parse_commit_files(commit_data)
    local files = {}
    local in_files = false
    for line in commit_data:gmatch("[^\n]+") do
        if in_files then
            local fname, bhash = line:match("^%s*(%S+)%s+(%S+)$")
            if fname and bhash then
                files[fname] = bhash
            end
        elseif line == "files:" then
            in_files = true
        end
    end
    return files
end

-- Command: diff <commit1> <commit2>
local function cmd_diff(hash1, hash2)
    if not hash1 or not hash2 then
        io.stderr:write("Usage: minigit diff <commit1> <commit2>\n")
        os.exit(1)
    end

    local data1 = read_file(COMMITS_DIR .. "/" .. hash1)
    if not data1 then
        print("Invalid commit")
        os.exit(1)
    end
    local data2 = read_file(COMMITS_DIR .. "/" .. hash2)
    if not data2 then
        print("Invalid commit")
        os.exit(1)
    end

    local files1 = parse_commit_files(data1)
    local files2 = parse_commit_files(data2)

    -- Collect all filenames
    local all_files = {}
    local seen = {}
    for f, _ in pairs(files1) do
        if not seen[f] then all_files[#all_files + 1] = f; seen[f] = true end
    end
    for f, _ in pairs(files2) do
        if not seen[f] then all_files[#all_files + 1] = f; seen[f] = true end
    end
    table.sort(all_files)

    for _, f in ipairs(all_files) do
        if not files1[f] and files2[f] then
            print("Added: " .. f)
        elseif files1[f] and not files2[f] then
            print("Removed: " .. f)
        elseif files1[f] ~= files2[f] then
            print("Modified: " .. f)
        end
    end

    os.exit(0)
end

-- Command: checkout <commit_hash>
local function cmd_checkout(hash)
    if not hash then
        io.stderr:write("Usage: minigit checkout <commit_hash>\n")
        os.exit(1)
    end

    local data = read_file(COMMITS_DIR .. "/" .. hash)
    if not data then
        print("Invalid commit")
        os.exit(1)
    end

    local files = parse_commit_files(data)
    for fname, bhash in pairs(files) do
        local blob = read_file(OBJECTS_DIR .. "/" .. bhash)
        if blob then
            write_file(fname, blob)
        end
    end

    write_file(HEAD_FILE, hash)
    write_file(INDEX_FILE, "")
    print("Checked out " .. hash)
    os.exit(0)
end

-- Command: reset <commit_hash>
local function cmd_reset(hash)
    if not hash then
        io.stderr:write("Usage: minigit reset <commit_hash>\n")
        os.exit(1)
    end

    local data = read_file(COMMITS_DIR .. "/" .. hash)
    if not data then
        print("Invalid commit")
        os.exit(1)
    end

    write_file(HEAD_FILE, hash)
    write_file(INDEX_FILE, "")
    print("Reset to " .. hash)
    os.exit(0)
end

-- Command: rm <file>
local function cmd_rm(filename)
    if not filename then
        io.stderr:write("Usage: minigit rm <file>\n")
        os.exit(1)
    end

    local index = read_index()
    local found = false
    local new_index = {}
    for _, f in ipairs(index) do
        if f == filename then
            found = true
        else
            new_index[#new_index + 1] = f
        end
    end

    if not found then
        print("File not in index")
        os.exit(1)
    end

    write_index(new_index)
    os.exit(0)
end

-- Command: show <commit_hash>
local function cmd_show(hash)
    if not hash then
        io.stderr:write("Usage: minigit show <commit_hash>\n")
        os.exit(1)
    end

    local data = read_file(COMMITS_DIR .. "/" .. hash)
    if not data then
        print("Invalid commit")
        os.exit(1)
    end

    local ts = data:match("timestamp: ([^\n]+)")
    local msg = data:match("message: ([^\n]+)")
    local files = parse_commit_files(data)

    -- Sort filenames
    local sorted = {}
    for f, _ in pairs(files) do
        sorted[#sorted + 1] = f
    end
    table.sort(sorted)

    print("commit " .. hash)
    print("Date: " .. ts)
    print("Message: " .. msg)
    print("Files:")
    for _, f in ipairs(sorted) do
        print("  " .. f .. " " .. files[f])
    end
    os.exit(0)
end

-- Main
local function main()
    local args = arg
    if #args < 1 then
        io.stderr:write("Usage: minigit <command> [args]\n")
        os.exit(1)
    end

    local command = args[1]

    if command == "init" then
        cmd_init()
    elseif command == "add" then
        cmd_add(args[2])
    elseif command == "commit" then
        local commit_args = {}
        for i = 2, #args do
            commit_args[#commit_args + 1] = args[i]
        end
        cmd_commit(commit_args)
    elseif command == "status" then
        cmd_status()
    elseif command == "log" then
        cmd_log()
    elseif command == "diff" then
        cmd_diff(args[2], args[3])
    elseif command == "checkout" then
        cmd_checkout(args[2])
    elseif command == "reset" then
        cmd_reset(args[2])
    elseif command == "rm" then
        cmd_rm(args[2])
    elseif command == "show" then
        cmd_show(args[2])
    else
        io.stderr:write("Unknown command: " .. command .. "\n")
        os.exit(1)
    end
end

main()
