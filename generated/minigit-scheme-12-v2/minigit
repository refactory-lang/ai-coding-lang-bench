#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 binary-ports)
             (ice-9 textual-ports)
             (rnrs bytevectors)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex output
(define (minihash-bytes bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-file filename)
  (let* ((port (open-file filename "rb"))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash-bytes (make-bytevector 0))
        (minihash-bytes data))))

(define (minihash-string str)
  (minihash-bytes (string->utf8 str)))

;;; File utilities
(define (file-exists-regular? path)
  (and (file-exists? path)
       (eq? 'regular (stat:type (stat path)))))

(define (read-file-text path)
  (if (file-exists? path)
      (let* ((port (open-input-file path))
             (text (get-string-all port)))
        (close-port port)
        text)
      ""))

(define (write-file-text path content)
  (let ((port (open-output-file path)))
    (display content port)
    (close-port port)))

(define (read-lines path)
  (let ((text (read-file-text path)))
    (if (string=? text "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split text #\newline)))))

(define (ensure-dir path)
  (unless (file-exists? path)
    (mkdir path)))

;;; Commands

(define (cmd-init)
  (if (file-exists? ".minigit")
      (begin
        (display "Repository already initialized")
        (newline))
      (begin
        (ensure-dir ".minigit")
        (ensure-dir ".minigit/objects")
        (ensure-dir ".minigit/commits")
        (write-file-text ".minigit/index" "")
        (write-file-text ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists-regular? filename)
    (display "File not found")
    (newline)
    (exit 1))
  (let ((hash (minihash-file filename)))
    ;; Copy file content to objects
    (let* ((src (open-file filename "rb"))
           (data (get-bytevector-all src)))
      (close-port src)
      (let ((dst (open-file (string-append ".minigit/objects/" hash) "wb")))
        (unless (eof-object? data)
          (put-bytevector dst data))
        (close-port dst)))
    ;; Update index
    (let ((entries (read-lines ".minigit/index")))
      (unless (member filename entries)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit args)
  ;; Parse -m "message"
  (let ((message (get-commit-message args)))
    (let ((entries (read-lines ".minigit/index")))
      (when (null? entries)
        (display "Nothing to commit")
        (newline)
        (exit 1))
      (let* ((head-content (string-trim-both (read-file-text ".minigit/HEAD")))
             (parent (if (string=? head-content "") "NONE" head-content))
             (timestamp (current-time))
             (sorted-files (sort entries string<?))
             ;; Build file entries with their blob hashes
             (file-lines
              (map (lambda (f)
                     (let* ((hash (minihash-file f)))
                       (string-append f " " hash)))
                   sorted-files))
             ;; Build commit content
             (commit-content
              (string-append
               "parent: " parent "\n"
               "timestamp: " (number->string timestamp) "\n"
               "message: " message "\n"
               "files:\n"
               (string-join file-lines "\n")
               "\n"))
             (commit-hash (minihash-string commit-content)))
        ;; Write commit file
        (write-file-text (string-append ".minigit/commits/" commit-hash) commit-content)
        ;; Update HEAD
        (write-file-text ".minigit/HEAD" commit-hash)
        ;; Clear index
        (write-file-text ".minigit/index" "")
        ;; Print
        (display (string-append "Committed " commit-hash))
        (newline)))))

(define (get-commit-message args)
  ;; args should be ("-m" "message")
  (if (and (>= (length args) 2)
           (string=? (car args) "-m"))
      (cadr args)
      (begin
        (display "Usage: minigit commit -m \"message\"")
        (newline)
        (exit 1))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-text ".minigit/HEAD"))))
    (if (string=? head-content "")
        (begin
          (display "No commits")
          (newline))
        (log-traverse head-content #t))))

(define (log-traverse hash first?)
  (let* ((path (string-append ".minigit/commits/" hash))
         (content (read-file-text path))
         (lines (string-split content #\newline))
         (parent (parse-field "parent:" lines))
         (timestamp (parse-field "timestamp:" lines))
         (message (parse-field "message:" lines)))
    (unless first?
      (newline))
    (display (string-append "commit " hash))
    (newline)
    (display (string-append "Date: " timestamp))
    (newline)
    (display (string-append "Message: " message))
    (newline)
    (unless (string=? parent "NONE")
      (log-traverse parent #f))))

(define (parse-field prefix lines)
  (let loop ((ls lines))
    (if (null? ls)
        ""
        (let ((line (car ls)))
          (if (string-prefix? prefix line)
              (string-trim-both (substring line (string-length prefix)))
              (loop (cdr ls)))))))

(define (parse-commit-files content)
  ;; Parse the files section from commit content, return list of (filename . hash) pairs
  (let* ((lines (string-split content #\newline))
         (files-section #f)
         (result '()))
    (for-each
     (lambda (line)
       (cond
        (files-section
         (let ((trimmed (string-trim-both line)))
           (when (not (string=? trimmed ""))
             (let ((parts (string-split trimmed #\space)))
               (when (>= (length parts) 2)
                 (set! result (cons (cons (car parts) (cadr parts)) result)))))))
        ((string=? (string-trim-both line) "files:")
         (set! files-section #t))))
     lines)
    (reverse result)))

(define (cmd-status)
  (let ((entries (read-lines ".minigit/index")))
    (display "Staged files:")
    (newline)
    (if (null? entries)
        (begin (display "(none)") (newline))
        (for-each (lambda (f) (display f) (newline)) entries))))

(define (cmd-diff args)
  (when (< (length args) 2)
    (display "Usage: minigit diff <commit1> <commit2>")
    (newline)
    (exit 1))
  (let ((hash1 (car args))
        (hash2 (cadr args)))
    (let ((path1 (string-append ".minigit/commits/" hash1))
          (path2 (string-append ".minigit/commits/" hash2)))
      (unless (file-exists? path1)
        (display "Invalid commit") (newline) (exit 1))
      (unless (file-exists? path2)
        (display "Invalid commit") (newline) (exit 1))
      (let* ((files1 (parse-commit-files (read-file-text path1)))
             (files2 (parse-commit-files (read-file-text path2)))
             (all-names (sort (delete-duplicates
                               (append (map car files1) (map car files2)))
                              string<?)))
        (for-each
         (lambda (name)
           (let ((in1 (assoc name files1))
                 (in2 (assoc name files2)))
             (cond
              ((and in1 (not in2))
               (display (string-append "Removed: " name)) (newline))
              ((and (not in1) in2)
               (display (string-append "Added: " name)) (newline))
              ((not (string=? (cdr in1) (cdr in2)))
               (display (string-append "Modified: " name)) (newline)))))
         all-names)))))

(define (cmd-checkout args)
  (when (null? args)
    (display "Usage: minigit checkout <commit_hash>") (newline) (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit") (newline) (exit 1))
    (let ((files (parse-commit-files (read-file-text path))))
      (for-each
       (lambda (pair)
         (let* ((fname (car pair))
                (bhash (cdr pair))
                (blob-path (string-append ".minigit/objects/" bhash))
                (blob-port (open-file blob-path "rb"))
                (data (get-bytevector-all blob-port)))
           (close-port blob-port)
           (let ((out (open-file fname "wb")))
             (unless (eof-object? data)
               (put-bytevector out data))
             (close-port out))))
       files)
      (write-file-text ".minigit/HEAD" hash)
      (write-file-text ".minigit/index" "")
      (display (string-append "Checked out " hash))
      (newline))))

(define (cmd-reset args)
  (when (null? args)
    (display "Usage: minigit reset <commit_hash>") (newline) (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit") (newline) (exit 1))
    (write-file-text ".minigit/HEAD" hash)
    (write-file-text ".minigit/index" "")
    (display (string-append "Reset to " hash))
    (newline)))

(define (cmd-rm args)
  (when (null? args)
    (display "Usage: minigit rm <file>") (newline) (exit 1))
  (let* ((filename (car args))
         (entries (read-lines ".minigit/index")))
    (unless (member filename entries)
      (display "File not in index") (newline) (exit 1))
    (let ((new-entries (filter (lambda (e) (not (string=? e filename))) entries)))
      (write-file-text ".minigit/index"
                       (if (null? new-entries)
                           ""
                           (string-append (string-join new-entries "\n") "\n"))))))

(define (cmd-show args)
  (when (null? args)
    (display "Usage: minigit show <commit_hash>") (newline) (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit") (newline) (exit 1))
    (let* ((content (read-file-text path))
           (lines (string-split content #\newline))
           (timestamp (parse-field "timestamp:" lines))
           (message (parse-field "message:" lines))
           (files (parse-commit-files content)))
      (display (string-append "commit " hash)) (newline)
      (display (string-append "Date: " timestamp)) (newline)
      (display (string-append "Message: " message)) (newline)
      (display "Files:") (newline)
      (for-each
       (lambda (pair)
         (display (string-append "  " (car pair) " " (cdr pair)))
         (newline))
       files))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>")
    (newline)
    (exit 1))
  (let ((cmd (cadr args))
        (rest (cddr args)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (if (null? rest)
          (begin (display "Usage: minigit add <file>") (newline) (exit 1))
          (cmd-add (car rest))))
     ((string=? cmd "commit") (cmd-commit rest))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "diff") (cmd-diff rest))
     ((string=? cmd "checkout") (cmd-checkout rest))
     ((string=? cmd "reset") (cmd-reset rest))
     ((string=? cmd "rm") (cmd-rm rest))
     ((string=? cmd "show") (cmd-show rest))
     (else
      (display (string-append "Unknown command: " cmd))
      (newline)
      (exit 1)))))

(main (command-line))
