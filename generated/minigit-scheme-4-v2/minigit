#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 match)
             (rnrs bytevectors)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define MOD64 (expt 2 64))

(define (minihash bv)
  (let loop ((i 0) (h 1469598103934665603))
    (if (>= i (bytevector-length bv))
        (format #f "~16,'0x" (modulo h MOD64))
        (let* ((b (bytevector-u8-ref bv i))
               (h2 (logxor h b))
               (h3 (modulo (* h2 1099511628211) MOD64)))
          (loop (+ i 1) h3)))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

;;; File helpers
(define (file-exists? path)
  (access? path F_OK))

(define (directory-exists? path)
  (and (file-exists? path)
       (eq? 'directory (stat:type (stat path)))))

(define (read-file-bytes path)
  (call-with-input-file path
    (lambda (port)
      (get-bytevector-all port))
    #:binary #t))

(define (read-file-string path)
  (call-with-input-file path
    (lambda (port)
      (get-string-all port))))

(define (write-file-string path content)
  (call-with-output-file path
    (lambda (port)
      (put-string port content))))

(define (write-file-bytes path bv)
  (call-with-output-file path
    (lambda (port)
      (put-bytevector port bv))
    #:binary #t))

(define (read-lines path)
  (if (file-exists? path)
      (let ((content (read-file-string path)))
        (if (string=? content "")
            '()
            (filter (lambda (s) (not (string=? s "")))
                    (string-split content #\newline))))
      '()))

(define (ensure-directory path)
  (unless (directory-exists? path)
    (mkdir path)))

;;; Commands

(define (cmd-init)
  (if (directory-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (ensure-directory ".minigit")
        (ensure-directory ".minigit/objects")
        (ensure-directory ".minigit/commits")
        (write-file-string ".minigit/index" "")
        (write-file-string ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists? filename)
    (display "File not found\n")
    (exit 1))
  (let* ((bv (read-file-bytes filename))
         (hash (minihash bv))
         (obj-path (string-append ".minigit/objects/" hash)))
    (unless (file-exists? obj-path)
      (write-file-bytes obj-path bv))
    ;; Add to index if not present
    (let ((index (read-lines ".minigit/index")))
      (unless (member filename index)
        (call-with-output-file ".minigit/index"
          (lambda (port)
            (for-each (lambda (f) (format port "~a\n" f)) index)
            (format port "~a\n" filename))))))
  )

(define (cmd-commit args)
  ;; Parse -m "message"
  (let ((message (parse-commit-message args)))
    (let ((index (read-lines ".minigit/index")))
      (when (null? index)
        (display "Nothing to commit\n")
        (exit 1))
      (let* ((head-content (string-trim-both (read-file-string ".minigit/HEAD")))
             (parent (if (string=? head-content "") "NONE" head-content))
             (timestamp (number->string (current-time)))
             (sorted-files (sort index string<?))
             ;; Build file entries: filename blobhash
             (file-entries
              (map (lambda (f)
                     (let* ((bv (read-file-bytes f))
                            (hash (minihash bv)))
                       (string-append f " " hash)))
                   sorted-files))
             (commit-content
              (string-append
               "parent: " parent "\n"
               "timestamp: " timestamp "\n"
               "message: " message "\n"
               "files:\n"
               (string-join file-entries "\n")
               "\n"))
             (commit-hash (minihash-string commit-content))
             (commit-path (string-append ".minigit/commits/" commit-hash)))
        (write-file-string commit-path commit-content)
        (write-file-string ".minigit/HEAD" commit-hash)
        (write-file-string ".minigit/index" "")
        (format #t "Committed ~a\n" commit-hash)))))

(define (parse-commit-message args)
  ;; args is list of strings after "commit"
  ;; expect "-m" "message"
  (match args
    (("-m" msg . _) msg)
    (_ (display "Usage: minigit commit -m \"message\"\n")
       (exit 1))))

(define (cmd-log)
  (let ((head-content (string-trim-both (read-file-string ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (log-traverse head-content))))

(define (log-traverse hash)
  (let* ((path (string-append ".minigit/commits/" hash))
         (content (read-file-string path))
         (lines (string-split content #\newline)))
    ;; Parse parent, timestamp, message
    (let ((parent (parse-field "parent: " lines))
          (timestamp (parse-field "timestamp: " lines))
          (message (parse-field "message: " lines)))
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" message)
      (unless (string=? parent "NONE")
        (newline)
        (log-traverse parent)))))

(define (parse-field prefix lines)
  (let loop ((ls lines))
    (if (null? ls)
        ""
        (let ((line (car ls)))
          (if (and (>= (string-length line) (string-length prefix))
                   (string=? (substring line 0 (string-length prefix)) prefix))
              (substring line (string-length prefix))
              (loop (cdr ls)))))))

(define (cmd-status)
  (let ((index (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? index)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) index))))

(define (parse-commit-files content)
  ;; Parse files section from commit content
  (let* ((lines (string-split content #\newline))
         (after-files (let loop ((ls lines))
                        (cond
                         ((null? ls) '())
                         ((string=? (car ls) "files:") (cdr ls))
                         (else (loop (cdr ls)))))))
    ;; Each line is "filename blobhash"
    (filter-map
     (lambda (line)
       (if (string=? line "")
           #f
           (let ((parts (string-split line #\space)))
             (if (>= (length parts) 2)
                 (cons (car parts) (cadr parts))
                 #f))))
     after-files)))

(define (cmd-diff args)
  (when (< (length args) 2)
    (display "Usage: minigit diff <commit1> <commit2>\n")
    (exit 1))
  (let ((hash1 (car args))
        (hash2 (cadr args)))
    (let ((path1 (string-append ".minigit/commits/" hash1))
          (path2 (string-append ".minigit/commits/" hash2)))
      (unless (file-exists? path1)
        (display "Invalid commit\n")
        (exit 1))
      (unless (file-exists? path2)
        (display "Invalid commit\n")
        (exit 1))
      (let* ((files1 (parse-commit-files (read-file-string path1)))
             (files2 (parse-commit-files (read-file-string path2)))
             ;; Collect all filenames sorted
             (all-names (sort (delete-duplicates
                               (append (map car files1) (map car files2)))
                              string<?)))
        (for-each
         (lambda (name)
           (let ((in1 (assoc name files1))
                 (in2 (assoc name files2)))
             (cond
              ((and in1 (not in2))
               (format #t "Removed: ~a\n" name))
              ((and (not in1) in2)
               (format #t "Added: ~a\n" name))
              ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
               (format #t "Modified: ~a\n" name)))))
         all-names)))))

(define (cmd-checkout args)
  (when (null? args)
    (display "Usage: minigit checkout <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let ((files (parse-commit-files (read-file-string path))))
      (for-each
       (lambda (entry)
         (let* ((filename (car entry))
                (blob-hash (cdr entry))
                (blob-path (string-append ".minigit/objects/" blob-hash))
                (content (read-file-bytes blob-path)))
           (write-file-bytes filename content)))
       files))
    (write-file-string ".minigit/HEAD" hash)
    (write-file-string ".minigit/index" "")
    (format #t "Checked out ~a\n" hash)))

(define (cmd-reset args)
  (when (null? args)
    (display "Usage: minigit reset <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (write-file-string ".minigit/HEAD" hash)
    (write-file-string ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm args)
  (when (null? args)
    (display "Usage: minigit rm <file>\n")
    (exit 1))
  (let* ((filename (car args))
         (index (read-lines ".minigit/index")))
    (unless (member filename index)
      (display "File not in index\n")
      (exit 1))
    (let ((new-index (filter (lambda (f) (not (string=? f filename))) index)))
      (call-with-output-file ".minigit/index"
        (lambda (port)
          (for-each (lambda (f) (format port "~a\n" f)) new-index))))))

(define (cmd-show args)
  (when (null? args)
    (display "Usage: minigit show <commit_hash>\n")
    (exit 1))
  (let* ((hash (car args))
         (path (string-append ".minigit/commits/" hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-string path))
           (lines (string-split content #\newline))
           (timestamp (parse-field "timestamp: " lines))
           (message (parse-field "message: " lines))
           (files (parse-commit-files content)))
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" message)
      (display "Files:\n")
      (let ((sorted-files (sort files (lambda (a b) (string<? (car a) (car b))))))
        (for-each
         (lambda (entry)
           (format #t "  ~a ~a\n" (car entry) (cdr entry)))
         sorted-files)))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1))
        (rest (cddr args)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (null? rest)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (car rest)))
     ((string=? cmd "commit") (cmd-commit rest))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff") (cmd-diff rest))
     ((string=? cmd "checkout") (cmd-checkout rest))
     ((string=? cmd "reset") (cmd-reset rest))
     ((string=? cmd "rm") (cmd-rm rest))
     ((string=? cmd "show") (cmd-show rest))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
