#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 match)
             (srfi srfi-1)
             (rnrs bytevectors))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h2 (logxor h b))
                 (h3 (modulo (* h2 1099511628211) mod64)))
            (loop (+ i 1) h3))))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

(define (minihash-file path)
  (let* ((port (open-input-file path #:binary #t))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

(define (file-read-text path)
  (let* ((port (open-input-file path))
         (text (get-string-all port)))
    (close-port port)
    (if (eof-object? text) "" text)))

(define (file-write-text path text)
  (let ((port (open-output-file path)))
    (put-string port text)
    (close-port port)))

(define (file-read-binary path)
  (let* ((port (open-input-file path #:binary #t))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data) (make-bytevector 0) data)))

(define (file-copy-binary src dst)
  (let ((data (file-read-binary src))
        (port (open-output-file dst #:binary #t)))
    (put-bytevector port data)
    (close-port port)))

(define (file-exists? path)
  (access? path F_OK))

(define (directory-exists? path)
  (and (file-exists? path)
       (eq? 'directory (stat:type (stat path)))))

(define (ensure-directory path)
  (unless (directory-exists? path)
    (mkdir path)))

(define (read-lines path)
  (if (file-exists? path)
      (let ((text (file-read-text path)))
        (if (string=? text "")
            '()
            (filter (lambda (s) (not (string=? s "")))
                    (string-split text #\newline))))
      '()))

(define (cmd-init)
  (if (directory-exists? ".minigit")
      (display "Repository already initialized\n")
      (begin
        (ensure-directory ".minigit")
        (ensure-directory ".minigit/objects")
        (ensure-directory ".minigit/commits")
        (file-write-text ".minigit/index" "")
        (file-write-text ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists? filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    (file-copy-binary filename (string-append ".minigit/objects/" hash))
    ;; Add to index if not already present
    (let ((lines (read-lines ".minigit/index")))
      (unless (member filename lines)
        (let ((port (open-file ".minigit/index" "a")))
          (put-string port (string-append filename "\n"))
          (close-port port))))))

(define (get-timestamp)
  (let ((t (current-time)))
    (number->string t)))

(define (cmd-commit message)
  (let ((index-lines (read-lines ".minigit/index")))
    (when (null? index-lines)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head-content (string-trim-both (file-read-text ".minigit/HEAD")))
           (parent (if (string=? head-content "") "NONE" head-content))
           (timestamp (get-timestamp))
           (sorted-files (sort index-lines string<?))
           (file-entries
            (string-join
             (map (lambda (f)
                    (let ((hash (minihash-file f)))
                      (string-append f " " hash)))
                  sorted-files)
             "\n"))
           (commit-content
            (string-append "parent: " parent "\n"
                           "timestamp: " timestamp "\n"
                           "message: " message "\n"
                           "files:\n"
                           file-entries "\n"))
           (commit-hash (minihash-string commit-content)))
      (file-write-text (string-append ".minigit/commits/" commit-hash) commit-content)
      (file-write-text ".minigit/HEAD" commit-hash)
      (file-write-text ".minigit/index" "")
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-status)
  (let ((index-lines (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? index-lines)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) index-lines))))

(define (parse-commit-files content)
  "Parse the files section of a commit, returning list of (filename . hash) pairs."
  (let* ((lines (string-split content #\newline))
         (in-files #f)
         (result '()))
    (for-each (lambda (line)
                (cond
                 ((string=? line "files:")
                  (set! in-files #t))
                 ((and in-files (not (string=? line "")))
                  (let ((parts (string-split line #\space)))
                    (when (>= (length parts) 2)
                      (set! result (cons (cons (car parts) (cadr parts)) result)))))))
              lines)
    (reverse result)))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists? path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists? path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((files1 (parse-commit-files (file-read-text path1)))
           (files2 (parse-commit-files (file-read-text path2)))
           (all-names (sort (delete-duplicates
                             (append (map car files1) (map car files2)))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((in1 (assoc name files1))
               (in2 (assoc name files2)))
           (cond
            ((and in1 (not in2))
             (format #t "Removed: ~a\n" name))
            ((and (not in1) in2)
             (format #t "Added: ~a\n" name))
            ((and in1 in2 (not (string=? (cdr in1) (cdr in2))))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-log)
  (let ((head-content (string-trim-both (file-read-text ".minigit/HEAD"))))
    (if (string=? head-content "")
        (display "No commits\n")
        (let loop ((hash head-content) (first #t))
          (when (and (not (string=? hash "NONE")) (not (string=? hash "")))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (file-read-text path))
                   (lines (string-split content #\newline)))
              (unless first (newline))
              (format #t "commit ~a\n" hash)
              ;; Parse timestamp and message
              (let parse ((ls lines) (ts "") (msg ""))
                (if (null? ls)
                    (begin
                      (format #t "Date: ~a\n" ts)
                      (format #t "Message: ~a\n" msg)
                      ;; Find parent
                      (let ((parent-line (car lines)))
                        (let ((parent (substring parent-line 8)))
                          (loop parent #f))))
                    (let ((line (car ls)))
                      (cond
                       ((string-prefix? "timestamp: " line)
                        (parse (cdr ls) (substring line 11) msg))
                       ((string-prefix? "message: " line)
                        (parse (cdr ls) ts (substring line 9)))
                       (else
                        (parse (cdr ls) ts msg))))))))))))

(define (cmd-checkout commit-hash)
  (let ((path (string-append ".minigit/commits/" commit-hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let ((files (parse-commit-files (file-read-text path))))
      (for-each
       (lambda (pair)
         (let* ((filename (car pair))
                (blob-hash (cdr pair))
                (blob-path (string-append ".minigit/objects/" blob-hash))
                (data (file-read-binary blob-path))
                (port (open-output-file filename #:binary #t)))
           (put-bytevector port data)
           (close-port port)))
       files)
      (file-write-text ".minigit/HEAD" commit-hash)
      (file-write-text ".minigit/index" "")
      (format #t "Checked out ~a\n" commit-hash))))

(define (cmd-reset commit-hash)
  (let ((path (string-append ".minigit/commits/" commit-hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (file-write-text ".minigit/HEAD" commit-hash)
    (file-write-text ".minigit/index" "")
    (format #t "Reset to ~a\n" commit-hash)))

(define (cmd-rm filename)
  (let ((lines (read-lines ".minigit/index")))
    (unless (member filename lines)
      (display "File not in index\n")
      (exit 1))
    (let ((new-lines (filter (lambda (f) (not (string=? f filename))) lines)))
      (file-write-text ".minigit/index"
                       (if (null? new-lines)
                           ""
                           (string-append (string-join new-lines "\n") "\n"))))))

(define (cmd-show commit-hash)
  (let ((path (string-append ".minigit/commits/" commit-hash)))
    (unless (file-exists? path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (file-read-text path))
           (lines (string-split content #\newline))
           (files (parse-commit-files content)))
      (format #t "commit ~a\n" commit-hash)
      ;; Parse timestamp and message
      (let parse ((ls lines) (ts "") (msg ""))
        (if (null? ls)
            (begin
              (format #t "Date: ~a\n" ts)
              (format #t "Message: ~a\n" msg)
              (display "Files:\n")
              (for-each
               (lambda (pair)
                 (format #t "  ~a ~a\n" (car pair) (cdr pair)))
               (sort files (lambda (a b) (string<? (car a) (car b))))))
            (let ((line (car ls)))
              (cond
               ((string-prefix? "timestamp: " line)
                (parse (cdr ls) (substring line 11) msg))
               ((string-prefix? "message: " line)
                (parse (cdr ls) ts (substring line 9)))
               (else
                (parse (cdr ls) ts msg)))))))))

(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      (when (< (length args) 4)
        (display "Usage: minigit commit -m <message>\n")
        (exit 1))
      (cmd-commit (list-ref args 3)))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit_hash>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit_hash>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit_hash>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
