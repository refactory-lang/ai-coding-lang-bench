#!/usr/bin/env guile
!#
(use-modules (ice-9 format)
             (ice-9 rdelim)
             (ice-9 regex)
             (ice-9 textual-ports)
             (ice-9 binary-ports)
             (ice-9 ftw)
             (rnrs bytevectors)
             (srfi srfi-1))

;;; MiniHash: FNV-1a variant, 64-bit, 16-char hex
(define (minihash bv)
  (let ((len (bytevector-length bv))
        (mod64 (expt 2 64)))
    (let loop ((i 0) (h 1469598103934665603))
      (if (>= i len)
          (format #f "~16,'0x" (modulo h mod64))
          (let* ((b (bytevector-u8-ref bv i))
                 (h1 (logxor h b))
                 (h2 (modulo (* h1 1099511628211) mod64)))
            (loop (+ i 1) h2))))))

(define (minihash-file filename)
  (let* ((port (open-input-file filename #:binary #t))
         (data (get-bytevector-all port)))
    (close-port port)
    (if (eof-object? data)
        (minihash (make-bytevector 0))
        (minihash data))))

(define (minihash-string str)
  (minihash (string->utf8 str)))

;;; File helpers
(define (file-exists-p path)
  (access? path F_OK))

(define (directory-exists-p path)
  (and (file-exists-p path)
       (eq? 'directory (stat:type (stat path)))))

(define (ensure-directory path)
  (unless (directory-exists-p path)
    (mkdir path)))

(define (read-file-string path)
  (if (file-exists-p path)
      (call-with-input-file path get-string-all)
      ""))

(define (write-file-string path content)
  (call-with-output-file path
    (lambda (port) (display content port))))

(define (read-lines path)
  (let ((content (read-file-string path)))
    (if (string=? content "")
        '()
        (filter (lambda (s) (not (string=? s "")))
                (string-split content #\newline)))))

;;; Commands

(define (cmd-init)
  (if (directory-exists-p ".minigit")
      (display "Repository already initialized\n")
      (begin
        (ensure-directory ".minigit")
        (ensure-directory ".minigit/objects")
        (ensure-directory ".minigit/commits")
        (write-file-string ".minigit/index" "")
        (write-file-string ".minigit/HEAD" ""))))

(define (cmd-add filename)
  (unless (file-exists-p filename)
    (display "File not found\n")
    (exit 1))
  (let ((hash (minihash-file filename)))
    ;; Copy file content to objects
    (let* ((src (open-input-file filename #:binary #t))
           (data (get-bytevector-all src)))
      (close-port src)
      (let ((dst (open-output-file (string-append ".minigit/objects/" hash) #:binary #t)))
        (unless (eof-object? data)
          (put-bytevector dst data))
        (close-port dst)))
    ;; Update index
    (let ((entries (read-lines ".minigit/index")))
      (unless (member filename entries)
        (let ((port (open-file ".minigit/index" "a")))
          (display filename port)
          (newline port)
          (close-port port))))))

(define (cmd-commit message)
  (let ((entries (read-lines ".minigit/index")))
    (when (null? entries)
      (display "Nothing to commit\n")
      (exit 1))
    (let* ((head (string-trim-both (read-file-string ".minigit/HEAD")))
           (parent (if (string=? head "") "NONE" head))
           (timestamp (number->string (current-time)))
           (sorted-files (sort entries string<?))
           ;; Build file lines with hashes
           (file-lines
            (map (lambda (f)
                   (let* ((hash (minihash-file f)))
                     (string-append f " " hash)))
                 sorted-files))
           ;; Build commit content
           (commit-content
            (string-append
             "parent: " parent "\n"
             "timestamp: " timestamp "\n"
             "message: " message "\n"
             "files:\n"
             (string-join file-lines "\n")
             "\n"))
           (commit-hash (minihash-string commit-content)))
      ;; Write commit file
      (write-file-string (string-append ".minigit/commits/" commit-hash) commit-content)
      ;; Update HEAD
      (write-file-string ".minigit/HEAD" commit-hash)
      ;; Clear index
      (write-file-string ".minigit/index" "")
      ;; Print
      (format #t "Committed ~a\n" commit-hash))))

(define (cmd-log)
  (let ((head (string-trim-both (read-file-string ".minigit/HEAD"))))
    (if (string=? head "")
        (display "No commits\n")
        (let loop ((hash head) (first #t))
          (when (and (not (string=? hash "")) (not (string=? hash "NONE")))
            (let* ((path (string-append ".minigit/commits/" hash))
                   (content (read-file-string path))
                   (lines (string-split content #\newline)))
              ;; Parse parent, timestamp, message
              (let ((parent "NONE")
                    (timestamp "")
                    (message ""))
                (for-each
                 (lambda (line)
                   (cond
                    ((string-prefix? "parent: " line)
                     (set! parent (substring line 8)))
                    ((string-prefix? "timestamp: " line)
                     (set! timestamp (substring line 11)))
                    ((string-prefix? "message: " line)
                     (set! message (substring line 9)))))
                 lines)
                (unless first (newline))
                (format #t "commit ~a\n" hash)
                (format #t "Date: ~a\n" timestamp)
                (format #t "Message: ~a\n" message)
                (loop parent #f))))))))

(define (cmd-status)
  (let ((entries (read-lines ".minigit/index")))
    (display "Staged files:\n")
    (if (null? entries)
        (display "(none)\n")
        (for-each (lambda (f) (format #t "~a\n" f)) entries))))

(define (parse-commit-files content)
  ;; Parse the files section from commit content
  (let* ((lines (string-split content #\newline))
         (in-files #f)
         (result '()))
    (for-each
     (lambda (line)
       (cond
        ((string=? line "files:")
         (set! in-files #t))
        (in-files
         (when (not (string=? line ""))
           (let ((parts (string-split line #\space)))
             (when (>= (length parts) 2)
               (set! result (cons (cons (car parts) (cadr parts)) result))))))))
     lines)
    (reverse result)))

(define (cmd-diff hash1 hash2)
  (let ((path1 (string-append ".minigit/commits/" hash1))
        (path2 (string-append ".minigit/commits/" hash2)))
    (unless (file-exists-p path1)
      (display "Invalid commit\n")
      (exit 1))
    (unless (file-exists-p path2)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((files1 (parse-commit-files (read-file-string path1)))
           (files2 (parse-commit-files (read-file-string path2)))
           ;; Collect all filenames
           (all-names (sort (delete-duplicates
                             (append (map car files1) (map car files2)))
                            string<?)))
      (for-each
       (lambda (name)
         (let ((h1 (assoc-ref files1 name))
               (h2 (assoc-ref files2 name)))
           (cond
            ((and (not h1) h2)
             (format #t "Added: ~a\n" name))
            ((and h1 (not h2))
             (format #t "Removed: ~a\n" name))
            ((and h1 h2 (not (string=? h1 h2)))
             (format #t "Modified: ~a\n" name)))))
       all-names))))

(define (cmd-checkout hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists-p path)
      (display "Invalid commit\n")
      (exit 1))
    (let ((files (parse-commit-files (read-file-string path))))
      (for-each
       (lambda (pair)
         (let* ((filename (car pair))
                (blob-hash (cdr pair))
                (blob-path (string-append ".minigit/objects/" blob-hash))
                (blob-port (open-input-file blob-path #:binary #t))
                (data (get-bytevector-all blob-port)))
           (close-port blob-port)
           (let ((out (open-output-file filename #:binary #t)))
             (unless (eof-object? data)
               (put-bytevector out data))
             (close-port out))))
       files)
      (write-file-string ".minigit/HEAD" hash)
      (write-file-string ".minigit/index" "")
      (format #t "Checked out ~a\n" hash))))

(define (cmd-reset hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists-p path)
      (display "Invalid commit\n")
      (exit 1))
    (write-file-string ".minigit/HEAD" hash)
    (write-file-string ".minigit/index" "")
    (format #t "Reset to ~a\n" hash)))

(define (cmd-rm filename)
  (let ((entries (read-lines ".minigit/index")))
    (unless (member filename entries)
      (display "File not in index\n")
      (exit 1))
    (let ((new-entries (filter (lambda (e) (not (string=? e filename))) entries)))
      (write-file-string ".minigit/index"
                         (if (null? new-entries)
                             ""
                             (string-append (string-join new-entries "\n") "\n"))))))

(define (cmd-show hash)
  (let ((path (string-append ".minigit/commits/" hash)))
    (unless (file-exists-p path)
      (display "Invalid commit\n")
      (exit 1))
    (let* ((content (read-file-string path))
           (lines (string-split content #\newline))
           (timestamp "")
           (message "")
           (files (parse-commit-files content)))
      (for-each
       (lambda (line)
         (cond
          ((string-prefix? "timestamp: " line)
           (set! timestamp (substring line 11)))
          ((string-prefix? "message: " line)
           (set! message (substring line 9)))))
       lines)
      (format #t "commit ~a\n" hash)
      (format #t "Date: ~a\n" timestamp)
      (format #t "Message: ~a\n" message)
      (display "Files:\n")
      (for-each
       (lambda (pair)
         (format #t "  ~a ~a\n" (car pair) (cdr pair)))
       files))))

;;; Main
(define (main args)
  (when (< (length args) 2)
    (display "Usage: minigit <command>\n")
    (exit 1))
  (let ((cmd (list-ref args 1)))
    (cond
     ((string=? cmd "init") (cmd-init))
     ((string=? cmd "add")
      (when (< (length args) 3)
        (display "Usage: minigit add <file>\n")
        (exit 1))
      (cmd-add (list-ref args 2)))
     ((string=? cmd "commit")
      ;; Parse -m "message"
      (let ((msg #f))
        (let loop ((i 2))
          (when (< i (length args))
            (when (string=? (list-ref args i) "-m")
              (when (< (+ i 1) (length args))
                (set! msg (list-ref args (+ i 1)))))
            (loop (+ i 1))))
        (unless msg
          (display "Usage: minigit commit -m <message>\n")
          (exit 1))
        (cmd-commit msg)))
     ((string=? cmd "status") (cmd-status))
     ((string=? cmd "log") (cmd-log))
     ((string=? cmd "diff")
      (when (< (length args) 4)
        (display "Usage: minigit diff <commit1> <commit2>\n")
        (exit 1))
      (cmd-diff (list-ref args 2) (list-ref args 3)))
     ((string=? cmd "checkout")
      (when (< (length args) 3)
        (display "Usage: minigit checkout <commit_hash>\n")
        (exit 1))
      (cmd-checkout (list-ref args 2)))
     ((string=? cmd "reset")
      (when (< (length args) 3)
        (display "Usage: minigit reset <commit_hash>\n")
        (exit 1))
      (cmd-reset (list-ref args 2)))
     ((string=? cmd "rm")
      (when (< (length args) 3)
        (display "Usage: minigit rm <file>\n")
        (exit 1))
      (cmd-rm (list-ref args 2)))
     ((string=? cmd "show")
      (when (< (length args) 3)
        (display "Usage: minigit show <commit_hash>\n")
        (exit 1))
      (cmd-show (list-ref args 2)))
     (else
      (format #t "Unknown command: ~a\n" cmd)
      (exit 1)))))

(main (command-line))
